<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:modeler="http://camunda.org/schema/modeler/1.0"
    id="Definitions_EpicFlow"
    targetNamespace="http://tecnos.co.jp/sdd/epic/EPIC-SAMPLE"
    exporter="Camunda Modeler" exporterVersion="5.20.0"
    modeler:executionPlatform="Camunda Cloud"
    modeler:executionPlatformVersion="8.8.0">

  <bpmn:collaboration id="Collaboration_EPIC-SAMPLE">
    <bpmn:documentation>営業部門とmcframe基幹システム間の受注管理連携フローを俯瞰する。
スコープ: 受注データ入力→mcframe在庫引当→承認判定→受注確定
スコープ外: 出荷・請求プロセス、在庫管理マスタメンテナンス
正本参照: epic_design.md epic_flow_descriptions.overview</bpmn:documentation>
    <bpmn:participant id="Participant_Sales" name="営業部門" processRef="Process_Sales">
      <bpmn:documentation>受注データの入力、引当結果の確認、承認判定の実施 (internal_team: TEAM-SLS)</bpmn:documentation>
    </bpmn:participant>
    <bpmn:participant id="Participant_ERP" name="mcframe基幹" processRef="Process_ERP">
      <bpmn:documentation>受注データの受信、在庫引当の実行、結果の返却 (external_system: mcframe運用チーム)</bpmn:documentation>
    </bpmn:participant>
    <bpmn:messageFlow id="MsgFlow_OrderReq" name="受注データ送信" sourceRef="Task_Sales_Send" targetRef="Task_ERP_Receive">
      <bpmn:documentation>営業部門からmcframeへの受注データ送信
ペイロード: 受注ヘッダ(顧客コード, 受注日) + 明細(品目コード, 数量, 単価)
Contract: CT-API-01 / Dependency: DEP-001
SLA: P95 &lt; 3s</bpmn:documentation>
    </bpmn:messageFlow>
    <bpmn:messageFlow id="MsgFlow_OrderRes" name="引当結果通知" sourceRef="Task_ERP_Respond" targetRef="Task_Sales_Confirm">
      <bpmn:documentation>mcframeから営業部門への引当結果通知
ペイロード: 引当結果(成功/失敗) + 引当数量 + 倉庫ID
Contract: CT-API-03 / Dependency: DEP-001
SLA: P95 &lt; 5s</bpmn:documentation>
    </bpmn:messageFlow>
  </bpmn:collaboration>

  <bpmn:process id="Process_Sales" name="営業部門">
    <bpmn:documentation>営業部門の受注処理フロー。受注データ入力からmcframeへの送信、引当結果確認、承認判定までを担当する。</bpmn:documentation>
    <bpmn:startEvent id="Start_Sales" name="受注依頼">
      <bpmn:outgoing>Flow_S1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Sales_Entry" name="受注データ入力">
      <bpmn:documentation>目的: 営業担当が顧客からの受注情報をシステムに入力する
入力: 顧客名, 品目, 数量, 希望納期
出力: 受注レコード</bpmn:documentation>
      <bpmn:incoming>Flow_S1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_Sales_Send" name="受注送信">
      <bpmn:documentation>目的: 入力済み受注データをmcframe基幹へ送信する
入力: 受注ヘッダ + 明細
出力: 送信確認(messageFlow: MsgFlow_OrderReq)</bpmn:documentation>
      <bpmn:incoming>Flow_S2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_Sales_Confirm" name="引当結果確認">
      <bpmn:documentation>目的: mcframeからの在庫引当結果を受信し確認する
入力: 引当結果(messageFlow: MsgFlow_OrderRes)
出力: 確認済み引当結果(成功/失敗, 引当数量, 倉庫ID)</bpmn:documentation>
      <bpmn:incoming>Flow_S3</bpmn:incoming>
      <bpmn:outgoing>Flow_S4</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:task id="Task_Sales_Approve" name="承認判定">
      <bpmn:documentation>目的: 受注金額に応じた承認ルートへ振り分ける
入力: 受注データ, 引当結果
出力: 承認結果(自動承認/部長承認/役員承認)
ルール: 100万円未満=自動, 100万円以上=部長, 500万円以上=役員</bpmn:documentation>
      <bpmn:incoming>Flow_S4</bpmn:incoming>
      <bpmn:outgoing>Flow_S5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Sales" name="受注確定">
      <bpmn:incoming>Flow_S5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_S1" sourceRef="Start_Sales" targetRef="Task_Sales_Entry" />
    <bpmn:sequenceFlow id="Flow_S2" sourceRef="Task_Sales_Entry" targetRef="Task_Sales_Send" />
    <bpmn:sequenceFlow id="Flow_S3" sourceRef="Task_Sales_Send" targetRef="Task_Sales_Confirm" />
    <bpmn:sequenceFlow id="Flow_S4" sourceRef="Task_Sales_Confirm" targetRef="Task_Sales_Approve" />
    <bpmn:sequenceFlow id="Flow_S5" sourceRef="Task_Sales_Approve" targetRef="End_Sales" />
  </bpmn:process>

  <bpmn:process id="Process_ERP" name="mcframe基幹">
    <bpmn:documentation>mcframe基幹システム側の受注処理フロー。営業部門からの受注を受信し、在庫引当を実行し、結果を返却する。</bpmn:documentation>
    <bpmn:startEvent id="Start_ERP" name="受信待機">
      <bpmn:outgoing>Flow_E1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:receiveTask id="Task_ERP_Receive" name="受注受信">
      <bpmn:documentation>目的: 営業部門から送信された受注データを受信する
入力: 受注ヘッダ + 明細(messageFlow: MsgFlow_OrderReq)
出力: 受信済み受注データ</bpmn:documentation>
      <bpmn:incoming>Flow_E1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:task id="Task_ERP_Allocate" name="在庫引当">
      <bpmn:documentation>目的: mcframe在庫引当APIを実行し、受注品目の在庫を確保する
入力: 品目コード, 数量, 倉庫コード
出力: 引当結果(成功/失敗), 引当数量, 倉庫ID</bpmn:documentation>
      <bpmn:incoming>Flow_E2</bpmn:incoming>
      <bpmn:outgoing>Flow_E3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_ERP_Respond" name="結果通知">
      <bpmn:documentation>目的: 在庫引当の結果を営業部門へ返却する
入力: 引当結果
出力: 結果通知(messageFlow: MsgFlow_OrderRes)</bpmn:documentation>
      <bpmn:incoming>Flow_E3</bpmn:incoming>
      <bpmn:outgoing>Flow_E4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_ERP" name="処理完了">
      <bpmn:incoming>Flow_E4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1" sourceRef="Start_ERP" targetRef="Task_ERP_Receive" />
    <bpmn:sequenceFlow id="Flow_E2" sourceRef="Task_ERP_Receive" targetRef="Task_ERP_Allocate" />
    <bpmn:sequenceFlow id="Flow_E3" sourceRef="Task_ERP_Allocate" targetRef="Task_ERP_Respond" />
    <bpmn:sequenceFlow id="Flow_E4" sourceRef="Task_ERP_Respond" targetRef="End_ERP" />

    <bpmn:textAnnotation id="Note_SLA">
      <bpmn:text>SLA: 受注送信 P95&lt;3s / 引当応答 P95&lt;5s (DEP-001)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Note_SLA" sourceRef="Note_SLA" targetRef="Task_ERP_Receive" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_EPIC-SAMPLE">

      <bpmndi:BPMNShape id="Participant_Sales_di" bpmnElement="Participant_Sales" isHorizontal="false">
        <dc:Bounds x="80" y="80" width="300" height="880" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ERP_di" bpmnElement="Participant_ERP" isHorizontal="false">
        <dc:Bounds x="460" y="80" width="300" height="880" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_Sales_di" bpmnElement="Start_Sales">
        <dc:Bounds x="212" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sales_Entry_di" bpmnElement="Task_Sales_Entry">
        <dc:Bounds x="175" y="240" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sales_Send_di" bpmnElement="Task_Sales_Send">
        <dc:Bounds x="175" y="400" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sales_Confirm_di" bpmnElement="Task_Sales_Confirm">
        <dc:Bounds x="175" y="600" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sales_Approve_di" bpmnElement="Task_Sales_Approve">
        <dc:Bounds x="175" y="760" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Sales_di" bpmnElement="End_Sales">
        <dc:Bounds x="212" y="900" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_ERP_di" bpmnElement="Start_ERP">
        <dc:Bounds x="592" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ERP_Receive_di" bpmnElement="Task_ERP_Receive">
        <dc:Bounds x="555" y="400" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ERP_Allocate_di" bpmnElement="Task_ERP_Allocate">
        <dc:Bounds x="555" y="520" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ERP_Respond_di" bpmnElement="Task_ERP_Respond">
        <dc:Bounds x="555" y="640" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ERP_di" bpmnElement="End_ERP">
        <dc:Bounds x="592" y="760" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_S1_di" bpmnElement="Flow_S1">
        <di:waypoint x="230" y="176" />
        <di:waypoint x="230" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S2_di" bpmnElement="Flow_S2">
        <di:waypoint x="230" y="320" />
        <di:waypoint x="230" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S3_di" bpmnElement="Flow_S3">
        <di:waypoint x="230" y="480" />
        <di:waypoint x="230" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S4_di" bpmnElement="Flow_S4">
        <di:waypoint x="230" y="680" />
        <di:waypoint x="230" y="760" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_S5_di" bpmnElement="Flow_S5">
        <di:waypoint x="230" y="840" />
        <di:waypoint x="230" y="900" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_E1_di" bpmnElement="Flow_E1">
        <di:waypoint x="610" y="176" />
        <di:waypoint x="610" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_di" bpmnElement="Flow_E2">
        <di:waypoint x="610" y="480" />
        <di:waypoint x="610" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E3_di" bpmnElement="Flow_E3">
        <di:waypoint x="610" y="600" />
        <di:waypoint x="610" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E4_di" bpmnElement="Flow_E4">
        <di:waypoint x="610" y="720" />
        <di:waypoint x="610" y="760" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MsgFlow_OrderReq_di" bpmnElement="MsgFlow_OrderReq">
        <di:waypoint x="285" y="440" />
        <di:waypoint x="555" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_OrderRes_di" bpmnElement="MsgFlow_OrderRes">
        <di:waypoint x="555" y="680" />
        <di:waypoint x="285" y="680" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
