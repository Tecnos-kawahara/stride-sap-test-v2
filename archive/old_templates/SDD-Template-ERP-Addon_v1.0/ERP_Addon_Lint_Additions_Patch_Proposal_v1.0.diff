2) Add ERP addon validator module
======================================================================
diff --git a/sdd-templates/tools/erp_addon_exec_tracking.py b/sdd-templates/tools/erp_addon_exec_tracking.py
new file mode 100644
--- /dev/null
+++ b/sdd-templates/tools/erp_addon_exec_tracking.py
@@
+from __future__ import annotations
+from dataclasses import dataclass
+from pathlib import Path
+import re
+
+try:
+    import yaml
+except Exception:
+    yaml = None
+
+MODE_ORDER = {"autopilot": 0, "confirm": 1, "validate": 2}
+
+@dataclass
+class LintError:
+    code: str
+    message: str
+    details: list[str] | None = None
+
+def _read_text(p: Path) -> str:
+    return p.read_text(encoding="utf-8")
+
+def _parse_front_matter(md_text: str) -> dict:
+    if not md_text.startswith("---"):
+        return {}
+    # split by '\n---' (front matter terminator)
+    parts = md_text.split("\n---", 2)
+    if len(parts) < 3:
+        return {}
+    yml = parts[0].lstrip("-").strip()
+    if yaml is None:
+        return {}
+    try:
+        return yaml.safe_load(yml) or {}
+    except Exception:
+        return {}
+
+def _load_yaml_file(p: Path) -> dict:
+    if yaml is None or not p.exists():
+        return {}
+    try:
+        return yaml.safe_load(_read_text(p)) or {}
+    except Exception:
+        return {}
+
+def _recommended_mode(risk_flags: list[str], mode_policy: dict) -> str:
+    best = "autopilot"
+    for rule in mode_policy.get("rules", []):
+        flags = set(rule.get("if_any_risk_flags", []))
+        if flags.intersection(set(risk_flags)):
+            cand = rule.get("mode", "autopilot")
+            if MODE_ORDER.get(cand, 0) > MODE_ORDER.get(best, 0):
+                best = cand
+    return best
+
+def validate_erp_addon_execution_tracking(feature_path, approval_status, coverage_tier):
+    fp = Path(feature_path)
+    errs = []
+
+    work_items_dir = fp / "work_items"
+    basic_design = fp / "basic_design.md"
+    profile_on = False
+    if basic_design.exists():
+        fm = _parse_front_matter(_read_text(basic_design))
+        profile_on = (fm.get("execution_profile") == "erp_addon")
+    active = work_items_dir.exists() or profile_on
+    if not active:
+        return errs
+
+    if not approval_status.get("gate_5", False) and not (fp / "tasks.md").exists():
+        return errs
+
+    mode_policy = _load_yaml_file(Path("memory/erp_addon_mode_policy.yaml"))
+    taxonomy = _load_yaml_file(Path("memory/erp_addon_risk_taxonomy.yaml"))
+    known_flags = set((taxonomy.get("risk_flags") or {}).keys())
+
+    if not work_items_dir.exists():
+        errs.append(("WI_DIR_MISSING", "work_items/ is required after Gate5 for ERP addon execution tracking.", []))
+        return errs
+
+    wi_files = sorted(work_items_dir.glob("WI-*.md"))
+    if not wi_files:
+        errs.append(("WI_SCHEMA_INVALID", "No Work Item files found (WI-*.md).", []))
+        return errs
+
+    state_path = fp / "state" / "state.yaml"
+    if not state_path.exists():
+        errs.append(("STATE_MISSING", "state/state.yaml is required after Gate5.", []))
+        state = {}
+    else:
+        state = _load_yaml_file(state_path)
+    state_wis = {w.get("wi_id") for w in (state.get("work_items") or []) if isinstance(w, dict)}
+
+    for wip in wi_files:
+        fm = _parse_front_matter(_read_text(wip))
+        missing = [k for k in ["wi_id", "title", "mode", "risk_flags"] if k not in fm]
+        if missing:
+            errs.append(("WI_SCHEMA_INVALID", f"{wip.name}: missing keys {missing}", []))
+            continue
+        wi_id = fm.get("wi_id")
+        mode = fm.get("mode")
+        risk_flags = fm.get("risk_flags") or []
+
+        if mode not in MODE_ORDER:
+            errs.append(("WI_MODE_INVALID", f"{wip.name}: invalid mode '{mode}'", []))
+        bad_flags = [f for f in risk_flags if f not in known_flags]
+        if bad_flags:
+            errs.append(("WI_RISK_FLAG_INVALID", f"{wip.name}: unknown risk_flags {bad_flags}", []))
+        if state_wis and wi_id not in state_wis:
+            errs.append(("STATE_WI_MISMATCH", f"state.yaml missing wi_id {wi_id}", []))
+
+        if coverage_tier == "critical" and mode == "autopilot":
+            allowed = {"ui_only", "message_only", "test_only", "logging_only"}
+            if not set(risk_flags).issubset(allowed):
+                errs.append(("AUTOPILOT_FORBIDDEN_BY_TIER", f"{wi_id}: critical tier forbids autopilot for risk_flags={risk_flags}", []))
+
+        rec = _recommended_mode(list(risk_flags), mode_policy)
+        if MODE_ORDER.get(mode, 0) < MODE_ORDER.get(rec, 0):
+            override = fm.get("mode_override") or {}
+            reason = override.get("reason")
+            if not reason:
+                errs.append(("MODE_OVERRIDE_REASON_MISSING", f"{wi_id}: mode '{mode}' weaker than recommended '{rec}' and no override reason.", []))
+            else:
+                errs.append(("WI_MODE_POLICY_VIOLATION", f"{wi_id}: mode '{mode}' weaker than recommended '{rec}'.", [f"override.reason: {reason}"]))
+
+        # approvals (confirm/validate) when executed (run exists) or state says in_progress/done
+        status = None
+        for sw in (state.get("work_items") or []):
+            if isinstance(sw, dict) and sw.get("wi_id") == wi_id:
+                status = sw.get("status")
+        has_runs = (fp / "runs" / str(wi_id)).exists()
+        if mode in ("confirm", "validate") and (status in ("in_progress", "done") or has_runs):
+            ap = work_items_dir / f"{wip.stem}.approval.md"
+            if not ap.exists():
+                errs.append(("WI_APPROVAL_PENDING", f"{wi_id}: missing approval file {ap.name}", []))
+            else:
+                txt = _read_text(ap)
+                need = ["plan_review"] if mode == "confirm" else ["design_diff_review", "plan_review"]
+                for n in need:
+                    if re.search(rf"\[x\].*{n}", txt, flags=re.IGNORECASE) is None:
+                        errs.append(("WI_APPROVAL_PENDING", f"{wi_id}: approval '{n}' not completed in {ap.name}", []))
+
+    # run evidence for done WIs
+    for sw in (state.get("work_items") or []):
+        if not isinstance(sw, dict):
+            continue
+        wi_id = sw.get("wi_id")
+        if sw.get("status") != "done" or not wi_id:
+            continue
+        wi_run_dir = fp / "runs" / str(wi_id)
+        if not wi_run_dir.exists():
+            errs.append(("RUN_MISSING", f"{wi_id}: status done but no runs directory", []))
+            continue
+        run_dirs = sorted([p for p in wi_run_dir.glob("RUN-*") if p.is_dir()])
+        if not run_dirs:
+            errs.append(("RUN_MISSING", f"{wi_id}: status done but no RUN-* found", []))
+            continue
+        latest = run_dirs[-1]
+        if not (latest / "walkthrough.md").exists():
+            errs.append(("WALKTHROUGH_MISSING", f"{wi_id}: missing walkthrough.md in {latest.name}", []))
+        if coverage_tier in ("critical", "standard") and not (latest / "test_results.md").exists():
+            errs.append(("TEST_RESULTS_MISSING", f"{wi_id}: missing test_results.md in {latest.name}", []))
+
+    if coverage_tier == "critical":
+        ops = fp / "ops"
+        required = ["release_checklist.md", "transport_manifest.yaml", "rollback_plan.md"]
+        missing_ops = [r for r in required if not (ops / r).exists()]
+        if missing_ops:
+            errs.append(("OPS_PACK_MISSING", f"critical tier requires ops pack: missing {missing_ops}", []))
+
+    return errs

