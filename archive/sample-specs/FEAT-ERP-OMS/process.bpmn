<?xml version="1.0" encoding="UTF-8"?>
<!--
  mcframe受注管理アドオン - 業務プロセス定義
  Feature: FEAT-ERP-OMS
  Version: 1.0

  フロー概要:
  1. 営業担当が受注データを入力
  2. 確認ダイアログで内容確認
  3. 受注データがDBに保存
  4. mcframe在庫引当APIで在庫確保
  5. 金額に応じた承認フロー分岐
  6. 全操作に監査ログを記録
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
             xmlns:modeler="http://camunda.org/schema/modeler/1.0"
             id="Definitions_1"
             targetNamespace="http://tecnos.co.jp/sdd/sample_erp_addon"
             exporter="Camunda Modeler" exporterVersion="5.20.0"
             modeler:executionPlatform="Camunda Cloud"
             modeler:executionPlatformVersion="8.8.0">

  <process id="BPMN-PROC-OMS" name="受注管理プロセス" isExecutable="true">

    <!-- Start Event -->
    <startEvent id="BPMN-EVT-001" name="受注依頼受領" />

    <!-- Task: 受注データ入力 -->
    <userTask id="BPMN-TASK-001" name="受注データ入力">
      <!-- AC: AC-US-FEATERPOMS-001-01, AC-US-FEATERPOMS-001-02 -->
      <!-- Contract: CT-API-01 (POST /api/orders) -->
    </userTask>

    <!-- Task: 在庫引当 -->
    <serviceTask id="BPMN-TASK-002" name="mcframe在庫引当">
      <!-- AC: AC-US-FEATERPOMS-001-03 -->
      <!-- Contract: CT-API-03 (POST /api/mcframe/stock-allocation) -->
      <extensionElements>
        <zeebe:taskDefinition type="mcframe-stock-allocation" retries="3" />
      </extensionElements>
    </serviceTask>

    <!-- Gateway: 金額判定 -->
    <exclusiveGateway id="BPMN-GW-001" name="金額判定ゲートウェイ">
      <!-- AC: AC-US-FEATERPOMS-002-01 -->
      <!-- 100万円未満: 自動承認 -->
      <!-- 100万円以上: 部長承認 -->
      <!-- 500万円以上: 役員承認 -->
    </exclusiveGateway>

    <!-- Task: 自動承認 -->
    <serviceTask id="BPMN-TASK-004" name="自動承認処理">
      <extensionElements>
        <zeebe:taskDefinition type="auto-approve" retries="1" />
      </extensionElements>
    </serviceTask>

    <!-- Task: 部長承認 -->
    <userTask id="BPMN-TASK-005" name="部長承認">
      <!-- Contract: CT-API-04 -->
    </userTask>

    <!-- Task: 役員承認 -->
    <userTask id="BPMN-TASK-006" name="役員承認">
      <!-- Contract: CT-API-04 -->
    </userTask>

    <!-- Gateway: 承認合流 -->
    <exclusiveGateway id="BPMN-GW-002" name="承認合流" />

    <!-- Task: 監査ログ記録 -->
    <serviceTask id="BPMN-TASK-003" name="監査ログ記録">
      <!-- AC: AC-US-FEATERPOMS-002-02 -->
      <!-- 全操作で呼び出し -->
      <extensionElements>
        <zeebe:taskDefinition type="audit-log-writer" retries="3" />
      </extensionElements>
    </serviceTask>

    <!-- End Event -->
    <endEvent id="BPMN-EVT-002" name="受注確定" />

    <!-- Sequence Flows -->
    <sequenceFlow id="BPMN-FLOW-001" sourceRef="BPMN-EVT-001" targetRef="BPMN-TASK-001" />
    <sequenceFlow id="BPMN-FLOW-002" sourceRef="BPMN-TASK-001" targetRef="BPMN-TASK-002" />
    <sequenceFlow id="BPMN-FLOW-003" sourceRef="BPMN-TASK-002" targetRef="BPMN-GW-001" />
    <sequenceFlow id="BPMN-FLOW-004" name="100万円未満" sourceRef="BPMN-GW-001" targetRef="BPMN-TASK-004" />
    <sequenceFlow id="BPMN-FLOW-005" name="100万円以上" sourceRef="BPMN-GW-001" targetRef="BPMN-TASK-005" />
    <sequenceFlow id="BPMN-FLOW-006" name="500万円以上" sourceRef="BPMN-GW-001" targetRef="BPMN-TASK-006" />
    <sequenceFlow id="BPMN-FLOW-007" sourceRef="BPMN-TASK-004" targetRef="BPMN-GW-002" />
    <sequenceFlow id="BPMN-FLOW-008" sourceRef="BPMN-TASK-005" targetRef="BPMN-GW-002" />
    <sequenceFlow id="BPMN-FLOW-009" sourceRef="BPMN-TASK-006" targetRef="BPMN-GW-002" />
    <sequenceFlow id="BPMN-FLOW-010" sourceRef="BPMN-GW-002" targetRef="BPMN-TASK-003" />
    <sequenceFlow id="BPMN-FLOW-011" sourceRef="BPMN-TASK-003" targetRef="BPMN-EVT-002" />

  </process>

  <!-- BPMNDiagram: Camunda Modeler 互換の図面データ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="BPMN-PROC-OMS">

      <bpmndi:BPMNShape id="Shape_EVT_001" bpmnElement="BPMN-EVT-001">
        <dc:Bounds x="160" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_001" bpmnElement="BPMN-TASK-001">
        <dc:Bounds x="260" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_002" bpmnElement="BPMN-TASK-002">
        <dc:Bounds x="420" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_001" bpmnElement="BPMN-GW-001" isMarkerVisible="true">
        <dc:Bounds x="585" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_004" bpmnElement="BPMN-TASK-004">
        <dc:Bounds x="700" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_005" bpmnElement="BPMN-TASK-005">
        <dc:Bounds x="700" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_006" bpmnElement="BPMN-TASK-006">
        <dc:Bounds x="700" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_002" bpmnElement="BPMN-GW-002" isMarkerVisible="true">
        <dc:Bounds x="865" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_TASK_003" bpmnElement="BPMN-TASK-003">
        <dc:Bounds x="980" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EVT_002" bpmnElement="BPMN-EVT-002">
        <dc:Bounds x="1140" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_FLOW_001" bpmnElement="BPMN-FLOW-001">
        <di:waypoint x="196" y="218" />
        <di:waypoint x="260" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_002" bpmnElement="BPMN-FLOW-002">
        <di:waypoint x="360" y="218" />
        <di:waypoint x="420" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_003" bpmnElement="BPMN-FLOW-003">
        <di:waypoint x="520" y="218" />
        <di:waypoint x="585" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_004" bpmnElement="BPMN-FLOW-004">
        <di:waypoint x="610" y="193" />
        <di:waypoint x="610" y="120" />
        <di:waypoint x="700" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_005" bpmnElement="BPMN-FLOW-005">
        <di:waypoint x="635" y="218" />
        <di:waypoint x="700" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_006" bpmnElement="BPMN-FLOW-006">
        <di:waypoint x="610" y="243" />
        <di:waypoint x="610" y="320" />
        <di:waypoint x="700" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_007" bpmnElement="BPMN-FLOW-007">
        <di:waypoint x="800" y="120" />
        <di:waypoint x="890" y="120" />
        <di:waypoint x="890" y="193" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_008" bpmnElement="BPMN-FLOW-008">
        <di:waypoint x="800" y="218" />
        <di:waypoint x="865" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_009" bpmnElement="BPMN-FLOW-009">
        <di:waypoint x="800" y="320" />
        <di:waypoint x="890" y="320" />
        <di:waypoint x="890" y="243" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_010" bpmnElement="BPMN-FLOW-010">
        <di:waypoint x="915" y="218" />
        <di:waypoint x="980" y="218" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FLOW_011" bpmnElement="BPMN-FLOW-011">
        <di:waypoint x="1080" y="218" />
        <di:waypoint x="1140" y="218" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
