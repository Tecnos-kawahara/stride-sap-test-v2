<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:modeler="http://camunda.org/schema/modeler/1.0"
    id="Definitions_EpicFlow"
    targetNamespace="http://tecnos.co.jp/sdd/epic/EPIC-XXX"
    exporter="Camunda Modeler" exporterVersion="5.20.0"
    modeler:executionPlatform="Camunda Cloud"
    modeler:executionPlatformVersion="8.8.0">

  <bpmn:collaboration id="Collaboration_EPIC-XXX">
    <bpmn:documentation>{{Epic overview の目的}}
スコープ: {{Epic のスコープ}}
スコープ外: {{スコープ外}}
正本参照: epic_design.md epic_flow_descriptions.overview</bpmn:documentation>
    <bpmn:participant id="Participant_A" name="{{Participant A Name}}" processRef="Process_A">
      <bpmn:documentation>{{責務概要}} ({{internal_team / external_system}})</bpmn:documentation>
    </bpmn:participant>
    <bpmn:participant id="Participant_B" name="{{Participant B Name}}" processRef="Process_B">
      <bpmn:documentation>{{責務概要}} ({{internal_team / external_system}})</bpmn:documentation>
    </bpmn:participant>
    <bpmn:messageFlow id="MsgFlow_AtoB" name="{{Message A to B}}" sourceRef="Task_A_Send" targetRef="Task_B_Receive">
      <bpmn:documentation>{{メッセージフロー概要}}
ペイロード: {{送受信データ}}
SLA: {{SLA}}</bpmn:documentation>
    </bpmn:messageFlow>
    <bpmn:messageFlow id="MsgFlow_BtoA" name="{{Message B to A}}" sourceRef="Task_B_Send" targetRef="Task_A_Receive">
      <bpmn:documentation>{{メッセージフロー概要}}
ペイロード: {{送受信データ}}
SLA: {{SLA}}</bpmn:documentation>
    </bpmn:messageFlow>
  </bpmn:collaboration>

  <bpmn:process id="Process_A" name="{{Participant A Name}}" isExecutable="false">
    <bpmn:documentation>{{Participant A の業務フロー概要}}</bpmn:documentation>
    <bpmn:startEvent id="Start_A" name="開始">
      <bpmn:outgoing>Flow_A_001</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_A_Prepare" name="{{準備タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}}
出力: {{主出力}}</bpmn:documentation>
      <bpmn:incoming>Flow_A_001</bpmn:incoming>
      <bpmn:outgoing>Flow_A_002</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_A_Send" name="{{送信タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}}
出力: {{主出力}} (messageFlow参照)</bpmn:documentation>
      <bpmn:incoming>Flow_A_002</bpmn:incoming>
      <bpmn:outgoing>Flow_A_003</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_A_Receive" name="{{受信タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}} (messageFlow参照)
出力: {{主出力}}</bpmn:documentation>
      <bpmn:incoming>Flow_A_003</bpmn:incoming>
      <bpmn:outgoing>Flow_A_004</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="End_A" name="完了">
      <bpmn:incoming>Flow_A_004</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_A_001" sourceRef="Start_A" targetRef="Task_A_Prepare" />
    <bpmn:sequenceFlow id="Flow_A_002" sourceRef="Task_A_Prepare" targetRef="Task_A_Send" />
    <bpmn:sequenceFlow id="Flow_A_003" sourceRef="Task_A_Send" targetRef="Task_A_Receive" />
    <bpmn:sequenceFlow id="Flow_A_004" sourceRef="Task_A_Receive" targetRef="End_A" />
  </bpmn:process>

  <bpmn:process id="Process_B" name="{{Participant B Name}}" isExecutable="false">
    <bpmn:documentation>{{Participant B の業務フロー概要}}</bpmn:documentation>
    <bpmn:startEvent id="Start_B" name="開始">
      <bpmn:outgoing>Flow_B_001</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:receiveTask id="Task_B_Receive" name="{{受信タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}} (messageFlow参照)
出力: {{主出力}}</bpmn:documentation>
      <bpmn:incoming>Flow_B_001</bpmn:incoming>
      <bpmn:outgoing>Flow_B_002</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:task id="Task_B_Process" name="{{処理タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}}
出力: {{主出力}}</bpmn:documentation>
      <bpmn:incoming>Flow_B_002</bpmn:incoming>
      <bpmn:outgoing>Flow_B_003</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_B_Send" name="{{送信タスク}}">
      <bpmn:documentation>目的: {{業務目的}}
入力: {{主入力}}
出力: {{主出力}} (messageFlow参照)</bpmn:documentation>
      <bpmn:incoming>Flow_B_003</bpmn:incoming>
      <bpmn:outgoing>Flow_B_004</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_B" name="完了">
      <bpmn:incoming>Flow_B_004</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_B_001" sourceRef="Start_B" targetRef="Task_B_Receive" />
    <bpmn:sequenceFlow id="Flow_B_002" sourceRef="Task_B_Receive" targetRef="Task_B_Process" />
    <bpmn:sequenceFlow id="Flow_B_003" sourceRef="Task_B_Process" targetRef="Task_B_Send" />
    <bpmn:sequenceFlow id="Flow_B_004" sourceRef="Task_B_Send" targetRef="End_B" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_EPIC-XXX">

      <bpmndi:BPMNShape id="Participant_A_di" bpmnElement="Participant_A" isHorizontal="false">
        <dc:Bounds x="80" y="80" width="300" height="780" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_B_di" bpmnElement="Participant_B" isHorizontal="false">
        <dc:Bounds x="460" y="80" width="300" height="780" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_A_di" bpmnElement="Start_A">
        <dc:Bounds x="212" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A_Prepare_di" bpmnElement="Task_A_Prepare">
        <dc:Bounds x="175" y="240" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A_Send_di" bpmnElement="Task_A_Send">
        <dc:Bounds x="175" y="400" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_A_Receive_di" bpmnElement="Task_A_Receive">
        <dc:Bounds x="175" y="600" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_A_di" bpmnElement="End_A">
        <dc:Bounds x="212" y="760" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_B_di" bpmnElement="Start_B">
        <dc:Bounds x="592" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_B_Receive_di" bpmnElement="Task_B_Receive">
        <dc:Bounds x="555" y="400" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_B_Process_di" bpmnElement="Task_B_Process">
        <dc:Bounds x="555" y="520" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_B_Send_di" bpmnElement="Task_B_Send">
        <dc:Bounds x="555" y="640" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_B_di" bpmnElement="End_B">
        <dc:Bounds x="592" y="760" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_A_001_di" bpmnElement="Flow_A_001">
        <di:waypoint x="230" y="176" />
        <di:waypoint x="230" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_002_di" bpmnElement="Flow_A_002">
        <di:waypoint x="230" y="320" />
        <di:waypoint x="230" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_003_di" bpmnElement="Flow_A_003">
        <di:waypoint x="230" y="480" />
        <di:waypoint x="230" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_004_di" bpmnElement="Flow_A_004">
        <di:waypoint x="230" y="680" />
        <di:waypoint x="230" y="760" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_B_001_di" bpmnElement="Flow_B_001">
        <di:waypoint x="610" y="176" />
        <di:waypoint x="610" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B_002_di" bpmnElement="Flow_B_002">
        <di:waypoint x="610" y="480" />
        <di:waypoint x="610" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B_003_di" bpmnElement="Flow_B_003">
        <di:waypoint x="610" y="600" />
        <di:waypoint x="610" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B_004_di" bpmnElement="Flow_B_004">
        <di:waypoint x="610" y="720" />
        <di:waypoint x="610" y="760" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MsgFlow_AtoB_di" bpmnElement="MsgFlow_AtoB">
        <di:waypoint x="285" y="440" />
        <di:waypoint x="555" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_BtoA_di" bpmnElement="MsgFlow_BtoA">
        <di:waypoint x="555" y="680" />
        <di:waypoint x="285" y="680" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
