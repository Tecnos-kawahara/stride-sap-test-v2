<?xml version="1.0" encoding="UTF-8"?>
<job>
<script language="JScript"><![CDATA[
// ============================================================
// SAP GUI Test Template (CONFIG-driven)
//
// Usage:
//   1. CONFIG セクションのみ編集してプログラム固有の情報を設定
//   2. 必要に応じて CUSTOM TESTS セクションに追加テストを記述
//   3. gui_test.js から実行:
//      node extensions/sap/tools/gui_test.js <this_file.wsf> [--auto]
//
// Protocol:
//   - gui_test.js は KEY=VALUE 形式の stdout を解析
//   - テスト結果: TEST_<i>_ID/DESC/STATUS/DETAIL/CHECK/CRITERIA
//   - スクリーンショット: SS_<name>=<filepath>
//   - Args: [screenshot_dir] [capture_ps1_path] [sap_gui_pid]
// ============================================================

// ============================================================
// [CONFIG] — ここだけ編集すれば標準テストが動く
// ============================================================
var CONFIG = {
  // --- 基本情報 ---
  program:          "ZLOAP000100",    // プログラム名
  transaction:      "SA38",           // 起動トランザクション
  selectionScreen:  "1000",           // 選択画面のスクリーン番号

  // --- ALV ---
  // ALV Grid のコントロールパス（CL_SALV_TABLE / CL_GUI_ALV_GRID で異なる）
  alvShellPath:     "wnd[0]/usr/cntlGRID1/shellcont/shell",

  // --- 選択画面フィールド ---
  // ctxt プレフィックス想定（Select-Options）。-LOW は自動付加。
  selectionFields:  ["S_VBELN", "S_AUART", "S_ERDAT", "S_KUNNR", "S_VKORG", "S_WERKS"],

  // --- 期待ALVカラム ---
  expectedColumns:  [
    "VBELN", "POSNR", "AUART", "ERDAT", "KUNNR", "KUNNR_NAME",
    "MATNR", "MAKTX", "KWMENG", "VRKME", "NETWR", "WAERK",
    "VKORG", "VKORG_TEXT", "WERKS", "GBSTA_TEXT"
  ],

  // --- データ内容確認（先頭行で空でないことをチェックするカラム） ---
  dataCheckColumns: ["VBELN", "AUART", "KUNNR_NAME", "VKORG", "VKORG_TEXT", "GBSTA_TEXT"],

  // --- フィルタテスト ---
  // field: 選択画面フィールド（ctxt prefix + "-LOW" 付き）
  // column: ALVカラム名（フィルタ値の一致検証に使用）
  filterTests: [
    { field: "S_VKORG-LOW", column: "VKORG", acId: "AC-001-01", name: "販売組織フィルタ" },
    { field: "S_WERKS-LOW", column: "WERKS", acId: "AC-001-02", name: "出荷プラントフィルタ" }
  ],

  // --- カラム内容チェック ---
  // column: チェック対象ALVカラム
  // threshold: 有効率の閾値 (0.95 = 95%以上が非空ならPASS)
  // checkRows: チェックする最大行数
  contentChecks: [
    { column: "GBSTA_TEXT", threshold: 0.95, checkRows: 50, acId: "AC-002-02", name: "ステータステキスト表示" },
    { column: "VKORG_TEXT", threshold: 1.0,  checkRows: 20, acId: "AC-002-01", name: "販売組織名称表示" }
  ],

  // --- 該当データなしテスト ---
  noDataField:      "S_VBELN-LOW",    // 使用するフィールド
  noDataValue:      "9999999999",     // 存在しない値

  // --- 回帰テスト（受注番号指定） ---
  // チェック対象カラム（先頭行の値がフィルタ前後で一致することを検証）
  regressionColumns: ["VBELN", "POSNR", "NETWR", "KUNNR_NAME"],
  regressionFilterField: "S_VBELN-LOW",

  // --- 必須デフォルト値 ---
  // clearSelection() 後に自動復元する値。必須入力フィールドのデフォルトに使用。
  // 例: mandatoryDefaults: { "S_WERKS-LOW": "1000", "S_BUKRS-LOW": "1000" }
  mandatoryDefaults: {},

  // --- 標準テスト有効/無効 ---
  // false にすると該当テストをスキップ
  enableT0_Launch:        true,
  enableT1_FieldCheck:    true,
  enableT2_ALVDisplay:    true,
  enableT3_ColumnCheck:   true,
  enableT4_DataCheck:     true,
  enableT5_BackNav:       true,
  enableT6_NoData:        true,
  enableT7_Filters:       true,   // filterTests 配列のテストを実行
  enableT8_ContentChecks: true,   // contentChecks 配列のテストを実行
  enableT9_Regression:    true,
  enableT10_Sort:         true,
  enableT11_Export:       true
};

// ============================================================
// [BOILERPLATE] — 以下は編集不要
// ============================================================

function out(k, v) { WScript.Echo(k + "=" + v); }

var testIndex = 0;
var ssDir = "";
var capturePsPath = "";
var sapPid = "";
var wshShell = new ActiveXObject("WScript.Shell");

if (WScript.Arguments.Count() > 0) ssDir = WScript.Arguments(0);
if (WScript.Arguments.Count() > 1) capturePsPath = WScript.Arguments(1);
if (WScript.Arguments.Count() > 2) sapPid = WScript.Arguments(2);

function pass(id, desc, detail, checkContent, criteria) {
  out("TEST_" + testIndex + "_ID", id);
  out("TEST_" + testIndex + "_DESC", desc);
  out("TEST_" + testIndex + "_STATUS", "PASS");
  out("TEST_" + testIndex + "_DETAIL", detail || "");
  if (checkContent) out("TEST_" + testIndex + "_CHECK", checkContent);
  if (criteria) out("TEST_" + testIndex + "_CRITERIA", criteria);
  testIndex++;
}

function fail(id, desc, detail, checkContent, criteria) {
  out("TEST_" + testIndex + "_ID", id);
  out("TEST_" + testIndex + "_DESC", desc);
  out("TEST_" + testIndex + "_STATUS", "FAIL");
  out("TEST_" + testIndex + "_DETAIL", detail || "");
  if (checkContent) out("TEST_" + testIndex + "_CHECK", checkContent);
  if (criteria) out("TEST_" + testIndex + "_CRITERIA", criteria);
  testIndex++;
}

function screenshot(name) {
  if (!ssDir) return;
  var filePath = ssDir + "\\" + name + ".png";
  try {
    ses.findById("wnd[0]").HardCopy(filePath, "PNG");
    out("SS_" + name, filePath);
  } catch(e) {
    if (capturePsPath) {
      var psCmd = "powershell -NoProfile -ExecutionPolicy Bypass -File \"" + capturePsPath + "\" -Keyword \"SAP\" -OutFile \"" + filePath + "\"";
      if (sapPid) psCmd += " -FilterPid " + sapPid;
      try {
        wshShell.Run(psCmd, 0, true);
        out("SS_" + name, filePath);
      } catch(e2) {
        out("SS_ERR_" + name, "HardCopy:" + e.message + " PS1:" + e2.message);
      }
    } else {
      out("SS_ERR_" + name, e.message);
    }
  }
}

// --- フィールド検索ヘルパー（ctxt/txt 両対応、SELECT-OPTIONS + PARAMETERS） ---
// SELECT-OPTIONS: GuiCTextField (ctxt) / GuiTextField (txt) + "-LOW"/"-HIGH" サフィックス
// PARAMETERS: GuiCTextField (ctxt) / GuiTextField (txt) サフィックスなし
// データ要素の型によりプレフィックスが異なるため、両方を試行する。
function findSelField(fieldName, suffix) {
  var s = suffix || "-LOW";
  var prefixes = ["ctxt", "txt"];
  // 1. SELECT-OPTIONS: ctxt/txt + fieldName + suffix (-LOW/-HIGH)
  for (var p = 0; p < prefixes.length; p++) {
    try {
      return ses.findById("wnd[0]/usr/" + prefixes[p] + fieldName + s);
    } catch(e) {}
  }
  // 2. PARAMETERS: ctxt/txt + fieldName (サフィックスなし)
  for (var p = 0; p < prefixes.length; p++) {
    try {
      return ses.findById("wnd[0]/usr/" + prefixes[p] + fieldName);
    } catch(e) {}
  }
  return null;
}

// --- ナビゲーション・ヘルパー ---
function goBackToSelection() {
  for (var b = 0; b < 5; b++) {
    try {
      var scr = "" + ses.Info.ScreenNumber;
      if (scr == CONFIG.selectionScreen) return;
      ses.findById("wnd[0]/tbar[0]/btn[3]").press();
      WScript.Sleep(500);
    } catch(x) { break; }
  }
}

function clearSelection() {
  for (var i = 0; i < CONFIG.selectionFields.length; i++) {
    var f = CONFIG.selectionFields[i];
    var lo = findSelField(f, "-LOW");
    if (lo) try { lo.text = ""; } catch(x){}
    var hi = findSelField(f, "-HIGH");
    if (hi) try { hi.text = ""; } catch(x){}
  }
  // Restore mandatory defaults (e.g. required selection fields)
  if (CONFIG.mandatoryDefaults) {
    for (var key in CONFIG.mandatoryDefaults) {
      var fieldName = key.replace(/-LOW$|-HIGH$/, "");
      var suffix = key.match(/-LOW$|-HIGH$/) ? key.match(/-LOW$|-HIGH$/)[0] : "-LOW";
      var el = findSelField(fieldName, suffix);
      if (el) try { el.text = CONFIG.mandatoryDefaults[key]; } catch(x){}
    }
  }
}

function getALVShell() {
  return ses.findById(CONFIG.alvShellPath);
}

function executeSelection() {
  ses.findById("wnd[0]").sendVKey(8);
  WScript.Sleep(3000);
}

// --- COM接続 ---
var ses;
try {
  var sapgui = GetObject("SAPGUI");
  var app = sapgui.GetScriptingEngine;
  if (!app) { out("CONNECT", "FAIL"); out("ERROR", "Scripting Engine is null"); out("TEST_COUNT", "0"); WScript.Quit(1); }
  var conn = app.Children(0);
  ses = conn.Children(0);
  out("CONNECT", "OK");
  out("SYSTEM", "" + ses.Info.SystemName);
  out("CLIENT", "" + ses.Info.Client);
  out("USER", "" + ses.Info.User);
} catch (e) {
  out("CONNECT", "FAIL"); out("ERROR", e.message); out("TEST_COUNT", "0"); WScript.Quit(1);
}

// ============================================================
// [STANDARD TESTS] — CONFIG に基づいて自動実行
// ============================================================

var tNum = 0; // テスト番号カウンタ

// --- T0: SA38 経由でプログラム起動 ---
if (CONFIG.enableT0_Launch) {
  var tid0 = "T" + tNum; tNum++;
  try {
    ses.StartTransaction(CONFIG.transaction);
    WScript.Sleep(1000);
    ses.findById("wnd[0]/usr/ctxtRS38M-PROGRAMM").text = CONFIG.program;
    ses.findById("wnd[0]").sendVKey(8);
    WScript.Sleep(1500);

    var screen0 = "" + ses.Info.ScreenNumber;
    var t0Check = CONFIG.transaction + " でプログラム名 " + CONFIG.program + " を入力し F8(実行) で選択画面へ遷移する";
    var t0Criteria = "選択画面（スクリーン番号 " + CONFIG.selectionScreen + "）が表示されること";
    if (screen0 == CONFIG.selectionScreen) {
      screenshot(tid0 + "_selection_screen");
      pass(tid0, CONFIG.transaction + "経由でプログラム起動", "スクリーン番号: " + screen0, t0Check, t0Criteria);
    } else {
      screenshot(tid0 + "_unexpected");
      fail(tid0, CONFIG.transaction + "経由でプログラム起動", "期待: スクリーン" + CONFIG.selectionScreen + ", 実際: " + screen0, t0Check, t0Criteria);
    }
  } catch (e) {
    screenshot(tid0 + "_error");
    fail(tid0, CONFIG.transaction + "経由でプログラム起動", e.message, CONFIG.transaction + "経由でプログラムを起動", "選択画面が表示されること");
  }
}

// --- T1: 選択画面フィールド存在確認 ---
if (CONFIG.enableT1_FieldCheck) {
  var tid1 = "T" + tNum; tNum++;
  try {
    var found1 = [], missing1 = [];
    for (var i1 = 0; i1 < CONFIG.selectionFields.length; i1++) {
      var el1 = findSelField(CONFIG.selectionFields[i1], "-LOW");
      if (el1) {
        found1.push(CONFIG.selectionFields[i1]);
      } else { missing1.push(CONFIG.selectionFields[i1]); }
    }
    screenshot(tid1 + "_selection_fields");
    var total1 = CONFIG.selectionFields.length;
    var t1Check = "選択画面に必須フィールド" + total1 + "項目（" + CONFIG.selectionFields.join(", ") + "）が存在するか確認";
    var t1Criteria = total1 + "項目すべてのフィールドが画面上に存在すること";
    if (missing1.length == 0) {
      pass(tid1, "選択画面フィールド存在確認 (" + found1.length + "/" + total1 + ")", "検出: " + found1.join(", "), t1Check, t1Criteria);
    } else {
      fail(tid1, "選択画面フィールド存在確認", "未検出: " + missing1.join(", "), t1Check, t1Criteria);
    }
  } catch (e) {
    fail(tid1, "選択画面フィールド存在確認", e.message, "選択画面フィールド確認", "すべてのフィールドが存在すること");
  }
}

// --- T2: フィルタなし実行 → ALV一覧表示 ---
if (CONFIG.enableT2_ALVDisplay) {
  var tid2 = "T" + tNum; tNum++;
  try {
    clearSelection();
    executeSelection();
    var screen2 = "" + ses.Info.ScreenNumber;
    var statusType2 = "";
    try { statusType2 = "" + ses.findById("wnd[0]/sbar").MessageType; } catch(x){}
    var t2Check = "選択条件を未入力のまま F8(実行) し、ALV一覧が表示されることを確認";
    var t2Criteria = "ALV Grid コントロールが画面上に存在し、1行以上のデータが表示されること";
    if (statusType2 == "E" || statusType2 == "A") {
      screenshot(tid2 + "_error");
      fail(tid2, "フィルタなし実行 - ALV一覧表示", "エラー: " + ses.findById("wnd[0]/sbar").Text, t2Check, t2Criteria);
    } else {
      var shell2 = null;
      try { shell2 = getALVShell(); } catch(x){}
      if (shell2) {
        var rowCount2 = shell2.RowCount;
        screenshot(tid2 + "_alv_displayed");
        pass(tid2, "フィルタなし実行 - ALV一覧表示 (" + rowCount2 + "件)", "スクリーン: " + screen2 + " / 件数: " + rowCount2, t2Check, t2Criteria);
      } else {
        screenshot(tid2 + "_no_alv");
        fail(tid2, "フィルタなし実行 - ALV一覧表示", "ALV Grid が見つからない (スクリーン: " + screen2 + ")", t2Check, t2Criteria);
      }
    }
  } catch (e) {
    screenshot(tid2 + "_exception");
    fail(tid2, "フィルタなし実行 - ALV一覧表示", e.message, "フィルタなし実行でALV表示確認", "ALV Gridが表示されること");
  }
}

// --- T3: ALV カラム検証 ---
if (CONFIG.enableT3_ColumnCheck) {
  var tid3 = "T" + tNum; tNum++;
  try {
    var shell3 = getALVShell();
    var colFound3 = [], colMissing3 = [];
    for (var c3 = 0; c3 < CONFIG.expectedColumns.length; c3++) {
      try { shell3.GetCellValue(0, CONFIG.expectedColumns[c3]); colFound3.push(CONFIG.expectedColumns[c3]); }
      catch(ex) { colMissing3.push(CONFIG.expectedColumns[c3]); }
    }
    var actualCount3 = shell3.ColumnCount;
    out("ALV_COL_COUNT", "" + actualCount3);
    out("ALV_COL_EXPECTED", "" + CONFIG.expectedColumns.length);
    out("ALV_COL_FOUND", colFound3.join(","));
    out("ALV_COL_MISSING", colMissing3.join(","));
    screenshot(tid3 + "_alv_columns");
    var t3Check = "ALV一覧に仕様で定義された" + CONFIG.expectedColumns.length + "カラムがすべて存在するか検証";
    var t3Criteria = "期待" + CONFIG.expectedColumns.length + "カラムすべてが存在すること";
    if (colMissing3.length == 0) {
      pass(tid3, "ALVカラム検証 (" + actualCount3 + "/" + CONFIG.expectedColumns.length + ")", "検出: " + colFound3.join(", "), t3Check, t3Criteria);
    } else {
      fail(tid3, "ALVカラム検証", "未検出: " + colMissing3.join(", "), t3Check, t3Criteria);
    }
  } catch (e) {
    fail(tid3, "ALVカラム検証", e.message, "ALVカラム検証", "期待カラムすべてが存在すること");
  }
}

// --- T4: ALV データ内容確認（先頭行） ---
if (CONFIG.enableT4_DataCheck) {
  var tid4 = "T" + tNum; tNum++;
  try {
    var shell4 = getALVShell();
    var emptyFields4 = [];
    var sampleVal4 = "";
    for (var d4 = 0; d4 < CONFIG.dataCheckColumns.length; d4++) {
      try {
        var val4 = "" + shell4.GetCellValue(0, CONFIG.dataCheckColumns[d4]);
        out("DATA_" + CONFIG.dataCheckColumns[d4], val4);
        if (val4 == "" || val4 == "undefined") emptyFields4.push(CONFIG.dataCheckColumns[d4]);
        else if (!sampleVal4) sampleVal4 = CONFIG.dataCheckColumns[d4] + "=" + val4;
      } catch(ex) { emptyFields4.push(CONFIG.dataCheckColumns[d4] + "(err)"); }
    }
    screenshot(tid4 + "_alv_data");
    var t4Check = "ALV先頭行の主要フィールド" + CONFIG.dataCheckColumns.length + "項目にデータが入っているか確認";
    var t4Criteria = CONFIG.dataCheckColumns.length + "項目すべてが空でない値を持つこと";
    if (emptyFields4.length == 0) {
      pass(tid4, "ALVデータ内容確認（主要項目）", sampleVal4, t4Check, t4Criteria);
    } else {
      fail(tid4, "ALVデータ内容確認（主要項目）", "空項目: " + emptyFields4.join(", "), t4Check, t4Criteria);
    }
  } catch (e) {
    fail(tid4, "ALVデータ内容確認", e.message, "ALVデータ内容確認", "主要フィールドが空でないこと");
  }
}

// --- T5: F3(戻る)で選択画面に復帰 ---
if (CONFIG.enableT5_BackNav) {
  var tid5 = "T" + tNum; tNum++;
  try {
    ses.findById("wnd[0]/tbar[0]/btn[3]").press();
    WScript.Sleep(500);
    var screen5 = "" + ses.Info.ScreenNumber;
    if (screen5 != CONFIG.selectionScreen) {
      ses.findById("wnd[0]/tbar[0]/btn[3]").press();
      WScript.Sleep(500);
      screen5 = "" + ses.Info.ScreenNumber;
    }
    screenshot(tid5 + "_back_to_selection");
    var t5Check = "ALV一覧画面で F3(戻る) を押下し、選択画面に復帰するか確認";
    var t5Criteria = "スクリーン番号が " + CONFIG.selectionScreen + "（選択画面）に戻ること";
    if (screen5 == CONFIG.selectionScreen) {
      pass(tid5, "F3(戻る)で選択画面に復帰", "スクリーン番号: " + screen5, t5Check, t5Criteria);
    } else {
      fail(tid5, "F3(戻る)で選択画面に復帰", "スクリーン: " + screen5, t5Check, t5Criteria);
    }
  } catch (e) {
    fail(tid5, "F3(戻る)で選択画面に復帰", e.message, "F3で選択画面に復帰", "選択画面に戻ること");
  }
}

// --- T6: 該当データなしシナリオ ---
if (CONFIG.enableT6_NoData) {
  var tid6 = "T" + tNum; tNum++;
  try {
    goBackToSelection();
    clearSelection();
    var ndEl = findSelField(CONFIG.noDataField.replace(/-LOW$|-HIGH$/,""), CONFIG.noDataField.match(/-LOW$|-HIGH$/) ? CONFIG.noDataField.match(/-LOW$|-HIGH$/)[0] : "-LOW");
    if (!ndEl) ndEl = ses.findById("wnd[0]/usr/ctxt" + CONFIG.noDataField);
    ndEl.text = CONFIG.noDataValue;
    ses.findById("wnd[0]").sendVKey(8);
    WScript.Sleep(1500);
    // MESSAGE TYPE 'I' はポップアップダイアログ(wnd[1])を表示する場合がある
    // ダイアログが開いていれば、テキストを読み取ってから Enter で閉じる
    var status6 = "";
    var type6 = "";
    var dialogHandled = false;
    try {
      var dlg = ses.findById("wnd[1]");
      if (dlg) {
        // ダイアログのテキストを取得（複数の場所にある可能性）
        try { status6 = "" + ses.findById("wnd[1]/usr/txtMESSTXT1").Text; } catch(x1) {
          try { status6 = "" + dlg.Text; } catch(x2) { status6 = "dialog detected"; }
        }
        type6 = "I";
        dialogHandled = true;
        screenshot(tid6 + "_no_data_dialog");
        dlg.sendVKey(0); // Enter でダイアログを閉じる
        WScript.Sleep(500);
      }
    } catch (dlgErr) {
      // wnd[1] が存在しない = ダイアログなし（ステータスバーにメッセージが出ている）
    }
    if (!dialogHandled) {
      try { status6 = "" + ses.findById("wnd[0]/sbar").Text; } catch(x){}
      try { type6 = "" + ses.findById("wnd[0]/sbar").MessageType; } catch(x){}
    }
    var screen6 = "" + ses.Info.ScreenNumber;
    screenshot(tid6 + "_no_data");
    var t6Check = "存在しない値（" + CONFIG.noDataValue + "）で実行し、該当データなし時の動作を確認";
    var t6Criteria = "警告(W)/情報(I)/エラー(E)メッセージが表示されるか、選択画面に留まること";
    if (screen6 == CONFIG.selectionScreen || type6 == "W" || type6 == "I" || type6 == "E" || dialogHandled) {
      pass(tid6, "該当データなしシナリオ", "[" + type6 + "] " + status6, t6Check, t6Criteria);
    } else {
      fail(tid6, "該当データなしシナリオ", "スクリーン: " + screen6 + " ステータス: " + status6, t6Check, t6Criteria);
    }
  } catch (e) {
    fail(tid6, "該当データなしシナリオ", e.message, "該当データなし時の動作確認", "異常終了しないこと");
  }
}

// --- T7+: 選択フィルタテスト（CONFIG.filterTests の各エントリ） ---
if (CONFIG.enableT7_Filters) {
  for (var ft = 0; ft < CONFIG.filterTests.length; ft++) {
    var ftest = CONFIG.filterTests[ft];
    var tidF = "T" + tNum; tNum++;
    goBackToSelection();
    try {
      clearSelection();
      executeSelection();
      var shellF = getALVShell();
      var totalRowsF = shellF.RowCount;
      var targetValF = "" + shellF.GetCellValue(0, ftest.column);
      out(tidF + "_TARGET", targetValF);
      out(tidF + "_TOTAL_ROWS", "" + totalRowsF);

      goBackToSelection();
      clearSelection();
      var ftEl = findSelField(ftest.field.replace(/-LOW$|-HIGH$/,""), ftest.field.match(/-LOW$|-HIGH$/) ? ftest.field.match(/-LOW$|-HIGH$/)[0] : "-LOW");
      if (!ftEl) ftEl = ses.findById("wnd[0]/usr/ctxt" + ftest.field);
      ftEl.text = targetValF;
      executeSelection();

      var shellFb = getALVShell();
      var filteredRowsF = shellFb.RowCount;
      var mismatchF = 0;
      var checkCountF = (filteredRowsF > 20) ? 20 : filteredRowsF;
      for (var rf = 0; rf < checkCountF; rf++) {
        if (("" + shellFb.GetCellValue(rf, ftest.column)) != targetValF) mismatchF++;
      }
      screenshot(tidF + "_filter_" + ftest.column);
      var fCheck = "選択画面で" + ftest.name + "(" + ftest.field.replace("-LOW", "") + ")=" + targetValF + " を指定して絞込";
      var fCriteria = "件数が減少し、全行の" + ftest.column + "が指定値と一致すること";
      if (filteredRowsF < totalRowsF && mismatchF == 0) {
        pass(tidF, ftest.name + " (" + ftest.acId + ")", ftest.column + "=" + targetValF + " / 全" + totalRowsF + "件 -> " + filteredRowsF + "件に絞込 / 不一致: 0", fCheck, fCriteria);
      } else if (mismatchF > 0) {
        fail(tidF, ftest.name + " (" + ftest.acId + ")", ftest.column + "不一致: " + mismatchF + "件", fCheck, fCriteria);
      } else {
        fail(tidF, ftest.name + " (" + ftest.acId + ")", "件数未減少: " + totalRowsF + " -> " + filteredRowsF, fCheck, fCriteria);
      }
    } catch (e) {
      screenshot(tidF + "_error");
      fail(tidF, ftest.name + " (" + ftest.acId + ")", e.message, ftest.name + "の動作確認", "指定値のデータのみ表示されること");
    }
  }
}

// --- T8+: カラム内容チェック（CONFIG.contentChecks の各エントリ） ---
if (CONFIG.enableT8_ContentChecks) {
  for (var cc = 0; cc < CONFIG.contentChecks.length; cc++) {
    var ctest = CONFIG.contentChecks[cc];
    var tidC = "T" + tNum; tNum++;

    // ALV画面に居なければ再実行
    try {
      var scrC = "" + ses.Info.ScreenNumber;
      if (scrC == CONFIG.selectionScreen) {
        goBackToSelection();
        clearSelection();
        executeSelection();
      }
    } catch(x) {}

    try {
      var shellC = getALVShell();
      var rowsC = shellC.RowCount;
      var checkRowsC = (rowsC > ctest.checkRows) ? ctest.checkRows : rowsC;
      var invalidC = 0;
      var valDistC = {};
      var sampleC = "";

      for (var rc = 0; rc < checkRowsC; rc++) {
        var vc = "" + shellC.GetCellValue(rc, ctest.column);
        if (vc == "" || vc == "undefined") {
          invalidC++;
        } else {
          valDistC[vc] = (valDistC[vc] || 0) + 1;
          if (!sampleC) sampleC = vc;
        }
      }

      var distList = [];
      for (var dk in valDistC) { distList.push(dk + ":" + valDistC[dk] + "件"); }

      screenshot(tidC + "_content_" + ctest.column);
      var ratioC = ((checkRowsC - invalidC) / checkRowsC * 100).toFixed(1);
      var cCheck = "ALV一覧の" + ctest.column + "列にデータが表示されているか確認（先頭" + checkRowsC + "行）";
      var cCriteria = ctest.column + "の" + (ctest.threshold * 100) + "%以上が有効な値であること";

      if (invalidC <= Math.ceil(checkRowsC * (1 - ctest.threshold))) {
        var detailC = "分布: " + distList.join(", ") + " (チェック" + checkRowsC + "行, 有効率: " + ratioC + "%)";
        if (invalidC > 0) detailC += " ※空行" + invalidC + "件(許容範囲内)";
        pass(tidC, ctest.name + " (" + ctest.acId + ")", detailC, cCheck, cCriteria);
      } else {
        fail(tidC, ctest.name + " (" + ctest.acId + ")", "空行: " + invalidC + "件 / チェック" + checkRowsC + "行 (有効率: " + ratioC + "%)", cCheck, cCriteria);
      }
    } catch (e) {
      screenshot(tidC + "_error");
      fail(tidC, ctest.name + " (" + ctest.acId + ")", e.message, ctest.column + "の表示確認", ctest.column + "に有効な値が表示されること");
    }
  }
}

// --- T9: 回帰テスト - 特定レコード指定 ---
if (CONFIG.enableT9_Regression) {
  var tidR = "T" + tNum; tNum++;
  goBackToSelection();
  try {
    clearSelection();
    executeSelection();
    var shellR1 = getALVShell();
    var targetVals = {};
    for (var tr = 0; tr < CONFIG.regressionColumns.length; tr++) {
      targetVals[CONFIG.regressionColumns[tr]] = "" + shellR1.GetCellValue(0, CONFIG.regressionColumns[tr]);
    }
    var targetKey = targetVals[CONFIG.regressionColumns[0]] || "";
    out(tidR + "_TARGET_KEY", targetKey);

    goBackToSelection();
    clearSelection();
    var rgEl = findSelField(CONFIG.regressionFilterField.replace(/-LOW$|-HIGH$/,""), CONFIG.regressionFilterField.match(/-LOW$|-HIGH$/) ? CONFIG.regressionFilterField.match(/-LOW$|-HIGH$/)[0] : "-LOW");
    if (!rgEl) rgEl = ses.findById("wnd[0]/usr/ctxt" + CONFIG.regressionFilterField);
    rgEl.text = targetKey;
    executeSelection();

    var shellR2 = getALVShell();
    var rowsR = shellR2.RowCount;
    var matchR = true;
    var detailR = [];
    for (var mr = 0; mr < CONFIG.regressionColumns.length; mr++) {
      var col = CONFIG.regressionColumns[mr];
      var actual = "" + shellR2.GetCellValue(0, col);
      detailR.push(col + "=" + actual);
      if (actual != targetVals[col]) matchR = false;
    }
    screenshot(tidR + "_regression");
    var rCheck = CONFIG.regressionColumns[0] + "=" + targetKey + " を指定して既存フィールドが正しく表示されることを確認";
    var rCriteria = "指定レコードの" + CONFIG.regressionColumns.join("・") + " がフィルタ前と一致すること";
    if (rowsR >= 1 && matchR) {
      pass(tidR, "回帰テスト (" + CONFIG.regressionColumns[0] + "指定)", detailR.join(" ") + " / " + rowsR + "件", rCheck, rCriteria);
    } else {
      fail(tidR, "回帰テスト (" + CONFIG.regressionColumns[0] + "指定)", "一致=" + matchR + " / " + detailR.join(" "), rCheck, rCriteria);
    }
  } catch (e) {
    screenshot(tidR + "_error");
    fail(tidR, "回帰テスト", e.message, "回帰テスト", "既存フィールドが一致すること");
  }
}

// --- T10: ALV ソート機能 ---
if (CONFIG.enableT10_Sort) {
  var tidS = "T" + tNum; tNum++;
  goBackToSelection();
  try {
    clearSelection();
    executeSelection();
    var shellS = getALVShell();
    var sortCol = CONFIG.expectedColumns[0]; // 先頭カラムでソート
    var beforeSort = "" + shellS.GetCellValue(0, sortCol);

    var sortOk = false;
    try { shellS.SelectColumn(sortCol); shellS.PressToolbarContextButton("&MB_SORT"); WScript.Sleep(300); shellS.SelectContextMenuItem("&SORT_DSC"); WScript.Sleep(1000); sortOk = true; } catch(e1) {
      try { shellS.SelectColumn(sortCol); shellS.PressToolbarButton("&SORT_DSC"); WScript.Sleep(1000); sortOk = true; } catch(e2) {
        try { ses.findById("wnd[0]/mbar/menu[3]").select(); WScript.Sleep(300); ses.findById("wnd[0]/mbar/menu[3]/menu[1]").select(); WScript.Sleep(1000); sortOk = true; } catch(e3) {
          try { shellS.ColumnHeaderClick(sortCol); WScript.Sleep(500); shellS.ColumnHeaderClick(sortCol); WScript.Sleep(500); sortOk = true; } catch(e4) {}
        }
      }
    }

    shellS = getALVShell();
    var afterSort = "" + shellS.GetCellValue(0, sortCol);
    var rowsS = shellS.RowCount;
    screenshot(tidS + "_alv_sort");
    var sCheck = "ALV一覧の" + sortCol + "列でソート操作を実行し、正常に動作することを確認";
    var sCriteria = "ソート操作がエラーなく完了すること";
    if (sortOk) {
      pass(tidS, "ALVソート機能", "ソート完了: 先頭" + sortCol + "=" + afterSort + " / ソート前=" + beforeSort + " / 全" + rowsS + "件", sCheck, sCriteria);
    } else {
      fail(tidS, "ALVソート機能", "ソートボタン/メニューにアクセスできませんでした", sCheck, sCriteria);
    }
  } catch (e) {
    screenshot(tidS + "_error");
    fail(tidS, "ALVソート機能", e.message, "ALVソート機能の確認", "ソートが正常に動作すること");
  }
}

// --- T11: ALV エクスポート機能 ---
if (CONFIG.enableT11_Export) {
  var tidE = "T" + tNum; tNum++;
  try {
    var shellE = getALVShell();
    var exportOk = false;
    var exportMethod = "";
    try { shellE.PressToolbarButton("&MB_EXPORT"); WScript.Sleep(500); exportOk = true; exportMethod = "ToolbarButton(&MB_EXPORT)"; ses.findById("wnd[0]").sendVKey(12); WScript.Sleep(300); } catch(e1) {
      try { shellE.PressToolbarButton("&XLSX"); WScript.Sleep(500); exportOk = true; exportMethod = "ToolbarButton(&XLSX)"; try { ses.findById("wnd[1]").sendVKey(12); } catch(x){} try { ses.findById("wnd[0]").sendVKey(12); } catch(x){} WScript.Sleep(300); } catch(e2) {
        try { ses.findById("wnd[0]/mbar/menu[0]").select(); WScript.Sleep(300); ses.findById("wnd[0]/mbar/menu[0]/menu[1]").select(); WScript.Sleep(300); exportOk = true; exportMethod = "MenuBar(List>Export)"; try { ses.findById("wnd[1]").sendVKey(12); } catch(x){} try { ses.findById("wnd[0]").sendVKey(12); } catch(x){} WScript.Sleep(300); } catch(e3) {}
      }
    }
    screenshot(tidE + "_export_menu");
    var eCheck = "ALV一覧からエクスポート機能にアクセスできるか確認";
    var eCriteria = "エクスポートメニュー/ダイアログが表示されること（ALV標準エクスポート機能が有効）";
    if (exportOk) {
      pass(tidE, "ALVエクスポート機能", "エクスポートアクセス成功: " + exportMethod, eCheck, eCriteria);
    } else {
      fail(tidE, "ALVエクスポート機能", "エクスポートメニューにアクセスできませんでした", eCheck, eCriteria);
    }
  } catch (e) {
    screenshot(tidE + "_error");
    fail(tidE, "ALVエクスポート機能", e.message, "ALVエクスポートの存在確認", "エクスポートが利用可能であること");
  }
}

// ============================================================
// [CUSTOM TESTS] — プロジェクト固有のテストをここに追加
// ============================================================

// 例:
// var tidCustom = "T" + tNum; tNum++;
// goBackToSelection();
// try {
//   // ...テストロジック...
//   screenshot(tidCustom + "_custom");
//   pass(tidCustom, "カスタムテスト名", "詳細", "確認内容", "判定基準");
// } catch (e) {
//   fail(tidCustom, "カスタムテスト名", e.message, "確認内容", "判定基準");
// }

// ============================================================
// [CLEANUP]
// ============================================================
try {
  goBackToSelection();
  ses.findById("wnd[0]/tbar[0]/btn[3]").press();
  WScript.Sleep(300);
} catch(x) {}

out("TEST_COUNT", "" + testIndex);
WScript.Quit(0);

]]></script>
</job>
