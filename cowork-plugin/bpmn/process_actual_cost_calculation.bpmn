    <bpmn:sequenceFlow id="BPMN-FLOW-UNALLOC-YES" sourceRef="BPMN-GW-010" targetRef="BPMN-TASK-081" name="あり">
      <bpmn:documentation>未配賦フラグあり → エラー対応</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= unallocatedFlagExists = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-UNALLOC-NO" sourceRef="BPMN-GW-010" targetRef="BPMN-GW-011" name="なし (default)">
      <bpmn:documentation>未配賦フラグなし → 確認結果エラー判定へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-ACTERR-YES" sourceRef="BPMN-GW-011" targetRef="BPMN-TASK-081" name="あり">
      <bpmn:documentation>エラーあり → 対応 → Phase 5 先頭へ再実行</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= actualCostError = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-ACTERR-NO" sourceRef="BPMN-GW-011" targetRef="BPMN-TASK-082" name="なし (default)">
