      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-039</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-040</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-040" name="工場間移動実績
ファイルの取込み">
      <bpmn:documentation>工場間移動実績ファイルを実績データ分解ツールに取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-040</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-041</bpmn:outgoing>
    </bpmn:userTask>
