      <bpmn:outgoing>BPMN-FLOW-045</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-045" name="入出庫実績情報
(廃棄実績) の作成">
      <bpmn:documentation>実績データ分解ツールにより、入出庫実績情報(廃棄実績)ファイルを作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-045</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-046</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-046" name="入出庫実績情報
(廃棄実績) の取込み">
      <bpmn:documentation>入出庫実績情報(廃棄実績)ファイルを「入出庫実績ＩＦ一覧(MGBBP0360)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-046</bpmn:incoming>
