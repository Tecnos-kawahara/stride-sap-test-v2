ファイルの取込み">
      <bpmn:documentation>購買実績情報ファイルを「購買実績ＩＦ一覧(MGBBP0310)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-038</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-039</bpmn:outgoing>
    </bpmn:userTask>
