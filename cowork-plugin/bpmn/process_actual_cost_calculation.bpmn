<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
    xmlns:modeler="http://camunda.org/schema/modeler/1.0"
    id="Definitions_actual_cost_calc"
    targetNamespace="http://tecnos.co.jp/sdd/actual_cost_calculation"
    exporter="Tecnos-STRIDE BPMN generator" exporterVersion="1.0.0"
    modeler:executionPlatform="Camunda Cloud"
    modeler:executionPlatformVersion="8.8.0">

  <bpmn:collaboration id="Collaboration_COSTCALC">
    <bpmn:documentation>月次原価計算プロセスの全体コラボレーション。4 レーン (ICT推進部 / 財務部・経理センター / CK本部 / ××工場) で構成。</bpmn:documentation>
    <bpmn:participant id="Participant_COSTCALC" name="月次原価計算プロセス" processRef="BPMN-PROC-COSTCALC" />
  </bpmn:collaboration>

  <bpmn:process id="BPMN-PROC-COSTCALC" name="月次実際原価計算プロセス" isExecutable="true">
    <bpmn:documentation>月次の実際原価計算プロセス全体フロー（Camunda 8 BPMN 2.0）。
本フローは「03-313_業務フロー定義書_実際原価計算_ver0.01.xlsx」の業務フロー「実際原価計算」シートを基に作成。

【プロセス構成】
Phase 1 ①マスタ作成・取込    : 当月新規発生の品目情報を mcframe に登録
Phase 2 ②見積原価・標準原価の登録 : 価格改定品目の標準原価を更新
Phase 3-1 ③-1 生産データ作成・取込 : 工程/投入/購買等の実績データを mcframe に取込
Phase 3-2 ③-2 実際原価計算 (仮実行) : 月末在庫数の確認と振替調整
Phase 4 ④費用データ取込       : OBIC給与・固定資産等から月次費用データ作成
Phase 5 ⑤実際原価計算実行     : 当月の実際原価計算を実行
Phase 6 ⑥原価確定             : 当月原価計算結果の確定
Phase 7 ⑦実際原価分析         : 各種レポートで原価分析
Phase 8 ⑧実値棚卸             : 月末実地棚卸 (前提条件なし／独立)

【関与レーン】
- ICT推進部           : マスタ登録、システム連携、エラー時の窓口
- 財務部・経理センター : 費用データ取込、原価分析
- CK本部 (購買管理課)  : 原価計算実行、ファイル取込み、エラー対応
- ××工場・××工場     : 実績収集、現場ファイル作成

【開始条件】月次原価計算開始日 (月初)
【完了条件】当月原価計算結果確定 + 実地棚卸完了
正本参照: 03-313_業務フロー定義書_実際原価計算_ver0.01.xlsx
</bpmn:documentation>

    <bpmn:laneSet id="LaneSet_COSTCALC">
      <bpmn:lane id="LANE_ICT" name="ICT推進部">
        <bpmn:flowNodeRef>BPMN-EVT-START</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-001</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-001</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-008</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-009</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-010</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-011</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-012</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-013</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-002</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-014</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-015</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-016</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-029</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LANE_FIN" name="財務部・経理センター">
        <bpmn:flowNodeRef>BPMN-TASK-068</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-071</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-074</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-075</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-076</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-086</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-087</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-088</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LANE_CK" name="CK本部">
        <bpmn:flowNodeRef>BPMN-TASK-002</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-003</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-018</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-020</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-021</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-022</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-023</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-024</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-025</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-026</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-027</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-004</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-028</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-030</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-031</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-032</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-033</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-034</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-035</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-036</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-037</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-038</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-040</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-041</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-042</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-044</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-045</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-046</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-048</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-049</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-050</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-055</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-056</bpmn:flowNodeRef>
