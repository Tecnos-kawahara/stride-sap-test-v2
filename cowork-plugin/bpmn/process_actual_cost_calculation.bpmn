      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-048</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-049</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-049" name="入出庫実績情報
(食堂等払出) の作成">
      <bpmn:documentation>実績データ分解ツールにより、入出庫実績情報(食堂等への払出実績)ファイルを作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-049</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-050</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-050" name="入出庫実績情報
(食堂等払出) の取込み">
      <bpmn:documentation>入出庫実績情報(食堂等への払出実績)ファイルを「入出庫実績ＩＦ一覧(MGBBP0360)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-050</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-051</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-051" name="原価実績データの作成
(投入実績用)">
      <bpmn:documentation>投入実績情報を取得するために、原価実績データを作成する (MGBBP0020 原価実績データ作成)。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-051</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-052</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-052" name="投入実績情報の取得">
      <bpmn:documentation>「投入実績一覧照会(MGBBP0120)」画面の「集計・グラフ」から投入実績情報をダウンロードし、mcframe取込用実績ファイルフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-052</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-053</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-053" name="棚卸実績ファイルの作成">
      <bpmn:documentation>棚卸実績ファイルを作成し、mcframe取込用実績ファイルフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-053</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-054</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-054" name="棚卸差異実績
ファイルの作成">
      <bpmn:documentation>棚差用実績データファイルを用いて、投入実績ファイルと棚卸実績ファイルの情報から、棚卸差異実績ファイルを作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-054</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-055</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-055" name="棚卸差異実績
ファイルの取込み">
      <bpmn:documentation>棚卸差異実績ファイルを実績データ分解ツールに取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-055</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-056</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-056" name="入出庫実績情報
(棚卸差異実績) の作成">
      <bpmn:documentation>実績データ分解ツールにより、入出庫実績情報(棚卸差異実績)ファイルを作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-056</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-057</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-057" name="入出庫実績情報
(棚卸差異実績) の取込み">
      <bpmn:documentation>入出庫実績情報(棚卸差異実績)ファイルを「入出庫実績ＩＦ一覧(MGBBP0360)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-057</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-058</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-058" name="原価実績データの作成">
      <bpmn:documentation>生産データから原価実績データを作成する (MGBBP0020 原価実績データ作成)。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-058</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-059</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-059" name="実際原価計算 (仮実行)">
      <bpmn:documentation>実際原価計算を実行 (MGBDP0010) する。
※目的：月末在庫数の確認のため</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-059</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-063</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-060</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-060" name="仮実行エラー確認">
      <bpmn:documentation>原価計算結果 (MGBDP0030) からエラーや未配賦の異常がないかを確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-060</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-061</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-061" name="仮実行エラー内容の分析">
      <bpmn:documentation>ログ情報 (MGBDP0050 原価計算ログ照会) からエラー詳細内容を確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-061</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-062</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-005" name="仮実行
確認結果エラー" default="BPMN-FLOW-TRIALERR-NO">
      <bpmn:documentation>仮実行のエラー有無を判定する。
あり → エラー対応 → Phase 3-2 先頭へ再実行
なし → 月末在庫確認へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-062</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-TRIALERR-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-TRIALERR-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-062" name="仮実行エラー対応の実施">
      <bpmn:documentation>エラー原因 (マスタ/実績連携データ/会計連携データ) の修正をする。
エラーは対象方法マニュアル参照。マニュアルに該当がなければテクノスに連絡する。
★修正後に Phase 3-2 先頭より再実行</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-TRIALERR-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-063</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-063" name="月末在庫確認">
      <bpmn:documentation>月末在庫を「受払原価一覧照会(MGBFP0150)」で確認する (検索条件：月末在庫ON)。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-TRIALERR-NO</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-064</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-064" name="前月末在庫との比較">
      <bpmn:documentation>前月末の棚卸在庫表と受払原価一覧照会の月末在庫を比較する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-064</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-065</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-006" name="実棚比較
結果" default="BPMN-FLOW-STOCK-OK">
      <bpmn:documentation>前月末との差が大きいか誤差範囲かを判定する。
差が大きい → 実績データ調査
誤差範囲 → 月末在庫調整判断へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-065</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-STOCK-DIFF</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-STOCK-OK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-065" name="実績データ調査・修正対象判定">
      <bpmn:documentation>実績データの調査結果で、間違いや漏れがあれば実績データを修正する。
間違いや漏れがなければ、実棚数に合わせて棚卸データによる投入実績に振替調整する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-STOCK-DIFF</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-066</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-007" name="実績修正の要否" default="BPMN-FLOW-FIX-NO">
      <bpmn:documentation>実績データ修正が必要か判定する。
要 → Phase 3-1 先頭より再実行
不要 → 棚卸差異登録 (Phase 3-1 棚卸差異処理) へ戻り → 月末在庫調整判断へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-066</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-FIX-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-FIX-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-066" name="入出庫実績 (棚卸) 作成">
      <bpmn:documentation>実棚数に合わせ、棚卸データによる投入実績への振替調整 (棚卸差異登録) を行う。
※Phase 3-1 棚卸差異処理 (Task 54-57) と同等の作業を実施</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-FIX-NO</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-COST-EXCLUDE</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-067</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-008" name="月末在庫調整
判断" default="BPMN-FLOW-ADJ-NO">
      <bpmn:documentation>終売品の月末在庫が０であるか確認する。
要 (０でない) → 廃棄登録 (入出庫実績(廃棄)作成) → 製造原価判定
不要 (０) → Phase 4 へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-STOCK-OK</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-067</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-ADJ-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-ADJ-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-067" name="入出庫実績 (廃棄) 作成">
      <bpmn:documentation>終売品の月末在庫が０でない場合、入出庫実績(廃棄)を作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-ADJ-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-068</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-009" name="製造原価への
含有判定" default="BPMN-FLOW-COST-EXCLUDE">
      <bpmn:documentation>廃棄実績を製造原価に含めるか判定する。
含む → Phase 3-1 先頭 (廃棄実績ファイル作成) より再実行
含まない → 棚卸差異登録 (棚卸差異処理) より再実行 → Phase 4 へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-068</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-COST-INCLUDE</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-COST-EXCLUDE</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-068" name="工場の人件費系の計上">
      <bpmn:documentation>OBIC(既存システムObic7)の給与データを基に人件費情報(製造給料/手当/超過勤務手当/臨時職員給/通勤費等)を企業経理システムへ連携する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-ADJ-NO</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-069</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-069" name="工場の燃料費系の計上">
      <bpmn:documentation>各費目ごとに①製造原価/物流原価/間接費に分解し、②製造原価については各部門(または原価工程)に付け替える。
※計上ルールは別紙計上ルールまとめ参照</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-069</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-070</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-070" name="工場の固定資産系の計上">
      <bpmn:documentation>工場の固定資産の当月中の登録・除却を申請する。
申請内容に従い、企業経理システムの固定資産登録モジュールにて固定資産名・減価償却額・費用負担部門(工程)を管理する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-070</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-071</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-071" name="CK本部の間接部門の計上">
      <bpmn:documentation>OBIC(既存システムObic7)の給与データを基にCK本部間接部門の人件費情報を企業経理システムへ連携する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-071</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-072</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-072" name="工場の修繕費・
その他系の計上">
      <bpmn:documentation>修繕費・製造一時費用については、支払伝票に勘定科目および費用負担部門(工程)を記載の上、財務部・事務センター向けに送付する。
財務部・事務センターは支払伝票に基づき企業経理システムに経費情報を登録する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-072</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-073</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-073" name="工場間配送費の計上">
      <bpmn:documentation>製造原価について、各部門(または原価工程)に付け替える。
※計上ルールは別紙計上ルールまとめ参照</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-073</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-074</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-074" name="月次費用データ
ファイルの作成">
      <bpmn:documentation>月次費用データファイルをmcframeフォーマットで作成し、会計データフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-074</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-075</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-075" name="月次費用データ
ファイルの取込み">
      <bpmn:documentation>月次費用データファイルを「配賦費用実績ＩＦ一覧(MGBGP0040)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-075</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-076</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-076" name="月次費用データ
取込み確認">
      <bpmn:documentation>月次費用データファイル取込みの結果を「配賦費用実績一覧照会(MGBGP0020)」(一次処理前のデータ)から参照して確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-076</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-077</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-077" name="実際原価計算">
      <bpmn:documentation>実際原価計算を実行 (MGBDP0010 原価計算実行) する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-077</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-082</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-078</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-078" name="実績エラー確認">
      <bpmn:documentation>原価計算結果 (MGBDP0030) からエラーや未配賦の異常がないかを確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-078</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-079</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-079" name="実績エラー内容の分析">
      <bpmn:documentation>ログ情報 (MGBDP0050 原価計算ログ照会) からエラー詳細内容を確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-079</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-080</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-080" name="未配賦の確認">
      <bpmn:documentation>「未配賦金額一覧(MGBDP0210)」で未配賦フラグの有無を確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-080</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-081</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-010" name="未配賦フラグの有無" default="BPMN-FLOW-UNALLOC-NO">
      <bpmn:documentation>未配賦フラグの有無を判定する。
あり → エラー対応 (原因修正)
なし → 確認結果エラー判定へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-081</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-UNALLOC-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-UNALLOC-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="BPMN-GW-011" name="実績
確認結果エラー" default="BPMN-FLOW-ACTERR-NO">
      <bpmn:documentation>実績原価計算のエラー有無を判定する。
あり → エラー対応 → Phase 5 先頭へ再実行
なし → Phase 6 (原価確定) へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-UNALLOC-NO</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-ACTERR-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-ACTERR-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-081" name="実績エラー対応の実施">
      <bpmn:documentation>エラー原因 (マスタ/実績連携データ/会計連携データ) の修正をする。
エラーは対象方法マニュアル参照。マニュアルに該当がなければテクノスに連絡する。
★修正後に Phase 5 先頭より再実行</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-UNALLOC-YES</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-ACTERR-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-082</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-082" name="実際原価計算の確定">
      <bpmn:documentation>当月原価計算結果を確定する (MGBDP0040 原価計算結果確定)。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-ACTERR-NO</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-083</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-083" name="月初在庫調整">
      <bpmn:documentation>当月原価計算結果を確定後、作成される月初在庫を調整する (MGBBP0210 月初在庫登録)。
原料、資材についての月初在庫を削除する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-083</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-084</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-084" name="原価分析">
      <bpmn:documentation>原価計算結果照会画面 (MGBDP0030) にて各種の分析を行う。
確定した実際原価計算の原価計算NOのデータを対象に分析する。
※財務部は原価実績分析の各メニューを必要に応じて確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-084</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-085</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-085" name="製品階層別
製造原価の把握">
      <bpmn:documentation>製品の階層別製造原価を把握する (MGBFP0020 完成原価一覧照会)。
外部で処理してレポートを見る場合は、画面からダウンロードして確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-085</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-086</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-086" name="部門・製品の階層別
製造原価の把握">
      <bpmn:documentation>工場における部門、製品の階層別製造原価(発生原価)を把握する。
(MGBFP0210 部門製造原価一覧照会、MGBFP0070 工程原価一覧照会)
外部で処理してレポートを見る場合は、画面からダウンロードして確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-086</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-087</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-087" name="見積原価と実際原価の
差異分析">
      <bpmn:documentation>製品の見積原価と実際原価の差異分析を行う (MGBFP0130 製造原価差異一覧照会)。
外部で処理してレポートを見る場合は、画面からダウンロードして確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-087</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-088</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-088" name="投入数量差異の把握">
      <bpmn:documentation>投入数量差異を把握する (MGBFP0140 製造原価差異内訳照会)。
外部で処理してレポートを見る場合は、画面からダウンロードして確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-088</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-089</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-089" name="製品の工程別
製造原価の把握">
      <bpmn:documentation>製品の工程別製造原価を把握する (MGBFP0020 完成原価一覧照会、MGBFP0200 原価内訳照会、MGBFP0070 工程原価一覧照会、MGBFP0080 工数原価一覧照会)。
外部で処理してレポートを見る場合は、画面からダウンロードして確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-089</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-090</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-090" name="実地棚卸">
      <bpmn:documentation>あらかじめ決定した中間品、原料、資材について月末に実地棚卸を行う (月末棚卸表作成)。
※前提条件：なし (Phase 8 は独立して実施)</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-090</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-091</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="BPMN-EVT-END" name="月次原価計算
完了">
      <bpmn:documentation>当月の実際原価計算プロセスが完了する。</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-091</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="BPMN-FLOW-001" sourceRef="BPMN-EVT-START" targetRef="BPMN-TASK-001">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-002" sourceRef="BPMN-TASK-001" targetRef="BPMN-GW-001">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-CODE-YES" sourceRef="BPMN-GW-001" targetRef="BPMN-TASK-002" name="あり">
      <bpmn:documentation>新規分類コード発番が必要 → CK本部購買課で分類コード決定</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= newClassCodeRequired = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-CODE-NO" sourceRef="BPMN-GW-001" targetRef="BPMN-TASK-003" name="なし (default)">
      <bpmn:documentation>新規分類コードは不要 → そのまま購買品品目情報の作成へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-003" sourceRef="BPMN-TASK-002" targetRef="BPMN-TASK-003">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-004" sourceRef="BPMN-TASK-003" targetRef="BPMN-TASK-004">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-005" sourceRef="BPMN-TASK-004" targetRef="BPMN-TASK-005">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-006" sourceRef="BPMN-TASK-005" targetRef="BPMN-TASK-006">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-007" sourceRef="BPMN-TASK-006" targetRef="BPMN-TASK-007">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-008" sourceRef="BPMN-TASK-007" targetRef="BPMN-TASK-008">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-009" sourceRef="BPMN-TASK-008" targetRef="BPMN-TASK-009">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-010" sourceRef="BPMN-TASK-009" targetRef="BPMN-TASK-010">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-011" sourceRef="BPMN-TASK-010" targetRef="BPMN-TASK-011">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-012" sourceRef="BPMN-TASK-011" targetRef="BPMN-TASK-012">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-013" sourceRef="BPMN-TASK-012" targetRef="BPMN-TASK-013">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-014" sourceRef="BPMN-TASK-013" targetRef="BPMN-GW-002">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STD-YES" sourceRef="BPMN-GW-002" targetRef="BPMN-TASK-014" name="あり">
      <bpmn:documentation>価格改定あり → 標準単価確定解除へ</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= priceRevisionExists = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STD-NO" sourceRef="BPMN-GW-002" targetRef="BPMN-TASK-016" name="なし (default)">
      <bpmn:documentation>価格改定なし → 標準原価情報ファイル取込みへ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-015" sourceRef="BPMN-TASK-014" targetRef="BPMN-TASK-015">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-016" sourceRef="BPMN-TASK-015" targetRef="BPMN-TASK-016">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-017" sourceRef="BPMN-TASK-016" targetRef="BPMN-TASK-017">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-018" sourceRef="BPMN-TASK-017" targetRef="BPMN-GW-003">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-RECIPE-INDIV" sourceRef="BPMN-GW-003" targetRef="BPMN-TASK-018" name="個別フォーマット">
      <bpmn:documentation>製麺・パントーストなど個別フォーマット → CK本部で手作業作成</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= recipeFormat = "individual"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-RECIPE-COMMON" sourceRef="BPMN-GW-003" targetRef="BPMN-TASK-019" name="共通フォーマット (default)">
      <bpmn:documentation>共通フォーマット → 工程実績連携ファイル作成へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-019" sourceRef="BPMN-TASK-018" targetRef="BPMN-TASK-019">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-020" sourceRef="BPMN-TASK-019" targetRef="BPMN-TASK-020">
    </bpmn:sequenceFlow>
