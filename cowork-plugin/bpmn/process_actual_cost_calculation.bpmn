    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-047" name="食堂等への払出実績
ファイルの作成">
      <bpmn:documentation>食堂等への払出実績ファイルを作成し、mcframe取込用実績ファイルフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-047</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-048</bpmn:outgoing>
    </bpmn:userTask>
