    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-022" sourceRef="BPMN-TASK-021" targetRef="BPMN-TASK-022">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-023" sourceRef="BPMN-TASK-022" targetRef="BPMN-TASK-023">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-024" sourceRef="BPMN-TASK-023" targetRef="BPMN-TASK-024">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-025" sourceRef="BPMN-TASK-024" targetRef="BPMN-TASK-025">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-026" sourceRef="BPMN-TASK-025" targetRef="BPMN-TASK-026">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-027" sourceRef="BPMN-TASK-026" targetRef="BPMN-TASK-027">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-028" sourceRef="BPMN-TASK-027" targetRef="BPMN-GW-004">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STDERR-YES" sourceRef="BPMN-GW-004" targetRef="BPMN-TASK-028" name="あり">
      <bpmn:documentation>エラーあり → 内容分析 → 対応 → Phase 3-1 先頭へ再実行</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= standardCostError = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STDERR-NO" sourceRef="BPMN-GW-004" targetRef="BPMN-TASK-030" name="なし (default)">
      <bpmn:documentation>エラーなし → 標準原価の確定へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-029" sourceRef="BPMN-TASK-028" targetRef="BPMN-TASK-029">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-030" sourceRef="BPMN-TASK-029" targetRef="BPMN-TASK-017">
      <bpmn:documentation>★修正後に Phase 3-1 先頭 (実績収集ファイルの集計) より再実行</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-031" sourceRef="BPMN-TASK-030" targetRef="BPMN-TASK-031">
