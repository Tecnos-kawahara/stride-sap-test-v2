    </bpmn:laneSet>

    <bpmn:startEvent id="BPMN-EVT-START" name="月次原価計算
開始">
      <bpmn:documentation>月初に当月分の実際原価計算プロセスを起動する。</bpmn:documentation>
      <bpmn:outgoing>BPMN-FLOW-001</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="BPMN-TASK-001" name="品目情報の更新">
      <bpmn:documentation>当月、新規に発生した製品/中間品/原料/資材の品目情報を更新する。
商品開発G(商品戦略本部開発G)で新商品情報を作成し、mcframe登録用の品目マスタを整備する。
・商品コードは商品企画にて付番し、「mcframe品目マスタ登録依頼書」へ記入する
・既存の原料/資材/中間品は既存コードを付番、新規はCK本部へ依頼</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-001</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-002</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-001" name="新規分類コード
発番有無" default="BPMN-FLOW-CODE-NO">
      <bpmn:documentation>新規品目に対して新たな分類コード発番が必要かを判定する。
あり → 分類コード決定 (CK本部購買課)
なし → 購買品品目情報の作成 (CK本部) へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-002</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-CODE-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-CODE-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-002" name="品目分類コードの決定">
      <bpmn:documentation>CK本部購買課が新製品発生時に新規分類コードを追加する場合、分類コードリストを作成する。
品目マスタファイルを外部マスタフォルダに保存する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-CODE-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-003</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-003" name="購買品品目情報の作成">
      <bpmn:documentation>購買部門にて新規材料・資材および中間品のコード発番を行い、「mcframe品目マスタ登録依頼書」へ記入し整備する。
・原料・資材：購買単位
・中間品：分類</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-CODE-NO</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-003</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-004</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-004" name="品目マスタファイルの作成">
      <bpmn:documentation>mcframe品目マスタ登録依頼書の内容を整備する (投入単位、出来高単位、換算値)。
新製品/新中間品がまとめ工程対象品目の場合、工場にて配賦係数を記入する。
外部マスタデータフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-004</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-005</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-005" name="材料・具材マスタの作成">
      <bpmn:documentation>工場で新製品製造に利用した品目情報から材料・具材マスタを作成する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-005</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-006</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-006" name="品目マスタの実績収集
フォーマットへの連携">
      <bpmn:documentation>新商品を製造するための品目情報を工程ごとに分離させ、各部で利用している製造実績・投入実績エクセルの「品目マスタ」シートに転記する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-006</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-007</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-007" name="実績収集の実施">
      <bpmn:documentation>最新化された製造実績・投入実績エクセルで、製造の実績収集を実施する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-007</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-008</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-008" name="品目単位マスタ
ファイルの作成">
      <bpmn:documentation>1. LOMANで当月新規に発生した品目単位情報を出力 (品目単位マスタ)。
2. 工場で新製品製造に利用した品目情報を外部マスタデータフォルダーに格納 (mcframe品目マスタ登録依頼書)。
3. 品目マスタ・投入シートを作成。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-008</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-009</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-009" name="分類コードリスト
ファイルの取込み">
      <bpmn:documentation>分類コードリストファイルに追加された分類コードを「品目分類マスタ登録(MABCP0340)」画面から取込み登録する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-009</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-010</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-010" name="品目マスタ
ファイルの取込み">
      <bpmn:documentation>品目マスタファイルを「品目マスタ一覧登録(MABCP0390)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-010</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-011</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-011" name="品目単位マスタ
ファイルの取込み">
      <bpmn:documentation>品目単位マスタファイルを「品目単位マスタ登録(MABCP0330)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-011</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-012</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-012" name="品目の使用開始">
      <bpmn:documentation>リリース登録(MABCP0400)を行い、品目が使用できる状態にする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-012</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-013</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-013" name="品目情報を原価へコピー">
      <bpmn:documentation>品目情報をSCMから原価側に追加取込み (MGBDP0500 原価品目情報登録) する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-013</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-014</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-002" name="標準原価
変更の有無" default="BPMN-FLOW-STD-NO">
      <bpmn:documentation>原材料の価格改定が発生したかを判定する。
あり → 標準単価確定解除 → 見積原価・標準原価作成
なし → そのまま標準原価情報ファイル取込みへ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-014</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-STD-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-STD-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-014" name="標準単価確定の解除">
      <bpmn:documentation>標準原価確定を解除して新しい価格の取込みを可能にする (MGBEP0110 標準単価確定)。
価格改定情報はCK本部購買管理課が各部署や工場から取り纏める。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-STD-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-015</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-015" name="見積原価・標準原価の作成">
      <bpmn:documentation>当月の実績原価計算実施後に発生した製品の見積原価、および原材料の標準原価をエクセルに記入する (標準原価情報)。
価格改定のあった原材料も作成する。
外部データフォルダーに格納する。
※多部門連携: 財務部・CK本部購買管理課・工場でmcframe品目マスタ登録依頼書/単価改定情報を確認・フィードバックする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-015</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-016</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-016" name="標準原価情報
ファイルの取込み">
      <bpmn:documentation>標準原価情報ファイルを「原価品目指値登録(MGBDP0620)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-STD-NO</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-016</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-017</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-017" name="実績収集ファイルの集計">
      <bpmn:documentation>××工場の各々の製造工程で入力された製造実績、および投入実績のエクセルファイルを各工場の工程実績ファイルフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-017</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-030</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-FIX-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-018</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-003" name="材料具材マスタ
のフォーマット" default="BPMN-FLOW-RECIPE-COMMON">
      <bpmn:documentation>対象品目の材料・具材マスタが個別フォーマットか共通フォーマットかを判定する。
個別 (製麺・パントースト) → CK本部にて手作業でレシピ情報作成
共通 → そのまま工程実績連携ファイル作成へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-018</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-RECIPE-INDIV</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-RECIPE-COMMON</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-018" name="レシピ情報
(個別フォーマット) の作成">
      <bpmn:documentation>××工場の「製麺」「パントースト」はAccess(工程実績編集アプリ)でレシピ情報を抽出できないため、CK本部で手作業で作成する。
投入実績データの材料・具材マスタのフォーマットを参考に標準レシピ取込用データに編集する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-RECIPE-INDIV</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-019</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-019" name="工程実績連携
ファイルの作成">
      <bpmn:documentation>工程実績ファイルから工程実績連携ファイル(製造実績/投入実績/作業実績)を作成し、指定フォルダーへ格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-RECIPE-COMMON</bpmn:incoming>
      <bpmn:incoming>BPMN-FLOW-019</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-020</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-020" name="レシピ情報
ファイルの取込み">
      <bpmn:documentation>投入実績エクセルから作成されたレシピ情報をもとに作成し、外部マスタデータフォルダーに格納する。
レシピ情報ファイルを実績データ分解ツールに取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-020</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-021</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-021" name="レシピ情報
ファイルの作成">
      <bpmn:documentation>実績データ分解ツールを実行し、レシピ情報から標準レシピ登録に必要なファイルを作成する:
1.原価品目詳細 / 2.原価品目工程 / 3.原価BOM / 4.標準レシピ変更リスト</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-021</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-022</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-022" name="標準レシピ確定の解除">
      <bpmn:documentation>標準レシピ変更リストをもとに標準原価確定 (MGBEP0110) を解除する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-022</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-023</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-023" name="原価品目詳細
ファイルの取込み">
      <bpmn:documentation>原価品目詳細ファイルを「原価品目詳細登録(MGBDP0510)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-023</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-024</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-024" name="原価品目工程
ファイルの取込み">
      <bpmn:documentation>原価品目工程ファイルを「原価品目工程登録(MGBDP0560)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-024</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-025</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-025" name="原価BOM
ファイルの取込み">
      <bpmn:documentation>原価BOMファイルを「原価BOM一覧登録(MGBDP0530)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-025</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-026</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-026" name="標準原価計算の実行">
      <bpmn:documentation>標準原価情報を登録した品目を、品目指定で標準原価計算 (MGBDP0010) する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-026</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-027</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-027" name="標準原価エラー確認">
      <bpmn:documentation>原価計算実行時のエラー発生有無を「原価計算結果確認(MGBDP0030)」で確認する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-027</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-028</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BPMN-GW-004" name="標準原価
確認結果エラー" default="BPMN-FLOW-STDERR-NO">
      <bpmn:documentation>エラー有無を判定する。
あり → エラー内容分析 → エラー対応 → 先頭(Phase 3-1)へ再実行
なし → 標準原価の確定へ</bpmn:documentation>
      <bpmn:incoming>BPMN-FLOW-028</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-STDERR-YES</bpmn:outgoing>
      <bpmn:outgoing>BPMN-FLOW-STDERR-NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="BPMN-TASK-028" name="標準原価エラー内容の分析">
      <bpmn:documentation>原価計算のログ (MGBDP0050 原価計算ログ照会) を参照してエラー内容を把握する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-STDERR-YES</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-029</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-029" name="標準原価エラー対応">
      <bpmn:documentation>エラー原因の修正を行う。
・マスタに関するエラーの場合、ICT推進部に連携する
・計算結果に関するエラーの場合、標準原価情報を確認する
マニュアルに該当がなければテクノスに連絡する。
★修正後に Phase 3-1 先頭より再実行</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-029</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-030</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-030" name="標準原価の確定">
      <bpmn:documentation>計算された標準原価を確定 (MGBEP0110 標準単価確定) する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-STDERR-NO</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-031</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-031" name="工程実績連携
ファイルの取込み">
      <bpmn:documentation>工程実績連携ファイル(製造実績/投入実績/作業実績)を実績データ分解ツールに取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-031</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-032</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-032" name="生産実績データの作成">
      <bpmn:documentation>実績データ分解ツールを実行し、当月の実績原価計算実施後からの生産実績データを作成する:
1.品目製造指図情報 / 2.指図工程情報 / 3.製造実績情報 / 4.投入実績情報 / 5.指図工数実績情報 / 6.購買実績情報
mcframe取込用実績ファイルフォルダーに格納する。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-032</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-033</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-033" name="品目製造指図情報
ファイルの取込み">
      <bpmn:documentation>品目製造指図情報ファイルを「品目製造指図情報一覧(MGBBP0030)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-033</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-034</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-034" name="指図工程情報
ファイルの取込み">
      <bpmn:documentation>指図工程情報ファイルを「指図工程情報一覧(MGBBP0040)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-034</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-035</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-035" name="製造実績情報
ファイルの取込み">
      <bpmn:documentation>製造実績情報ファイルを「製造実績ＩＦ一覧(MGBBP0300)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-035</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-036</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-036" name="投入実績情報
ファイルの取込み">
      <bpmn:documentation>投入実績情報ファイルを「投入実績ＩＦ一覧(MGBBP0320)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-036</bpmn:incoming>
      <bpmn:outgoing>BPMN-FLOW-037</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BPMN-TASK-037" name="指図工数実績情報
ファイルの取込み">
      <bpmn:documentation>指図工数実績情報ファイルを「指図工数実績ＩＦ一覧(MGBBP0330)」画面から取込みする。</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>BPMN-FLOW-037</bpmn:incoming>
