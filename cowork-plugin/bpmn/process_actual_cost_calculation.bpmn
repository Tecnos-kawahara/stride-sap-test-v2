    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-060" sourceRef="BPMN-TASK-059" targetRef="BPMN-TASK-060">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-061" sourceRef="BPMN-TASK-060" targetRef="BPMN-TASK-061">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-062" sourceRef="BPMN-TASK-061" targetRef="BPMN-GW-005">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-TRIALERR-YES" sourceRef="BPMN-GW-005" targetRef="BPMN-TASK-062" name="あり">
      <bpmn:documentation>仮実行エラーあり → 対応 → Phase 3-2 先頭へ再実行</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= trialCostError = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-TRIALERR-NO" sourceRef="BPMN-GW-005" targetRef="BPMN-TASK-063" name="なし (default)">
      <bpmn:documentation>仮実行エラーなし → 月末在庫確認へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-063" sourceRef="BPMN-TASK-062" targetRef="BPMN-TASK-059">
      <bpmn:documentation>★修正後に Phase 3-2 先頭 (実際原価計算 仮実行) より再実行</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-064" sourceRef="BPMN-TASK-063" targetRef="BPMN-TASK-064">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-065" sourceRef="BPMN-TASK-064" targetRef="BPMN-GW-006">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STOCK-DIFF" sourceRef="BPMN-GW-006" targetRef="BPMN-TASK-065" name="差が大きい">
      <bpmn:documentation>前月末在庫との差が大きい → 実績データ調査</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= stockDifferenceLarge = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-STOCK-OK" sourceRef="BPMN-GW-006" targetRef="BPMN-GW-008" name="誤差の範囲 (default)">
      <bpmn:documentation>誤差範囲 → 月末在庫調整判断へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-066" sourceRef="BPMN-TASK-065" targetRef="BPMN-GW-007">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-FIX-YES" sourceRef="BPMN-GW-007" targetRef="BPMN-TASK-017" name="要">
      <bpmn:documentation>実績修正要 → Phase 3-1 先頭 (実績収集ファイルの集計) より再実行</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= actualDataFixRequired = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-FIX-NO" sourceRef="BPMN-GW-007" targetRef="BPMN-TASK-066" name="不要 (default)">
      <bpmn:documentation>実績修正不要 → 棚卸差異登録 (入出庫実績(棚卸)作成)</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-067" sourceRef="BPMN-TASK-066" targetRef="BPMN-GW-008">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-ADJ-YES" sourceRef="BPMN-GW-008" targetRef="BPMN-TASK-067" name="要">
      <bpmn:documentation>終売品の月末在庫が０でない → 入出庫実績(廃棄)作成</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= adjustmentRequired = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-ADJ-NO" sourceRef="BPMN-GW-008" targetRef="BPMN-TASK-068" name="不要 (default)">
      <bpmn:documentation>調整不要 → Phase 4 (費用データ取込) へ</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-068" sourceRef="BPMN-TASK-067" targetRef="BPMN-GW-009">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-COST-INCLUDE" sourceRef="BPMN-GW-009" targetRef="BPMN-TASK-043" name="含む">
      <bpmn:documentation>製造原価に含む → Phase 3-1 廃棄実績ファイル作成より再実行</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= includeInCost = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="BPMN-FLOW-COST-EXCLUDE" sourceRef="BPMN-GW-009" targetRef="BPMN-TASK-066" name="含まない (default)">
      <bpmn:documentation>製造原価に含まない → 棚卸差異登録 (入出庫実績(棚卸)作成)</bpmn:documentation>
    </bpmn:sequenceFlow>
