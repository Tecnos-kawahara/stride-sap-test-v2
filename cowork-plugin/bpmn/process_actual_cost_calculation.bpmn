        <bpmn:flowNodeRef>BPMN-TASK-058</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-059</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-060</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-061</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-005</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-062</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-063</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-064</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-006</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-065</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-007</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-066</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-008</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-067</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-009</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-077</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-078</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-079</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-080</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-010</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-011</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-081</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-082</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-083</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-084</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-085</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-089</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-090</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-EVT-END</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="LANE_FAC" name="××工場・××工場">
        <bpmn:flowNodeRef>BPMN-TASK-004</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-005</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-006</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-007</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-017</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-GW-003</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-019</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-039</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-043</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-047</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-051</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-052</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-053</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-054</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-069</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-070</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-072</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BPMN-TASK-073</bpmn:flowNodeRef>
