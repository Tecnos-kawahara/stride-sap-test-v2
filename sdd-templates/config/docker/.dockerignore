# =============================================================================
# Docker Ignore File
# Exclude files from Docker build context
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.eggs/
.hypothesis/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
*.md
!README.md
LICENSE

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
specs/
coverage/
htmlcov/
.coverage
*.cover

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
azure-pipelines.yml

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.docker/

# -----------------------------------------------------------------------------
# Templates & Development
# -----------------------------------------------------------------------------
sdd-templates/
*.template
*.example
Makefile

# -----------------------------------------------------------------------------
# Logs & Temporary
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
