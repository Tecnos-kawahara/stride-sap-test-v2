class TestXXX_RESOURCEWorkflow:
    """Test complete workflows.

    Plan Reference: TS-INT-01
    """

    def test_complete_workflow(
        self, client, buyer_user, supplier_user, supplier_company
    ):
        """
        @ac AC-US-FEATXXX-006-01 - Complete workflow succeeds

        Given: Buyer and supplier users
        When: Execute full workflow (create -> process -> complete)
        Then: All steps succeed and history is recorded
        """
        # Step 1: Login as buyer
        client.post(
            "/api/v1/auth/login",
            json={"username": buyer_user["username"], "password": buyer_user["password"]},
        )

        # Step 2: Create resource
        create_response = client.post(
            "/api/v1/xxx_resource",
            json={
                "supplier_id": str(supplier_company.id),
                # ... other fields
            },
            headers={"Idempotency-Key": str(uuid.uuid4())},
        )
        assert create_response.status_code == 201
        resource_id = create_response.json()["id"]

        # Step 3: Login as supplier
        client.post(
            "/api/v1/auth/login",
            json={"username": supplier_user["username"], "password": supplier_user["password"]},
        )

        # Step 4: Supplier processes
        process_response = client.post(
            f"/api/v1/xxx_resource/{resource_id}/process",
            json={"status": "accepted"},
        )
        assert process_response.status_code == 200

        # Step 5: Login as buyer again
        client.post(
            "/api/v1/auth/login",
            json={"username": buyer_user["username"], "password": buyer_user["password"]},
        )

        # Step 6: Complete
        complete_response = client.post(
            f"/api/v1/xxx_resource/{resource_id}/complete",
            json={"notes": "Completed successfully"},
        )
        assert complete_response.status_code == 200

        # Step 7: Verify history
        detail_response = client.get(f"/api/v1/xxx_resource/{resource_id}")
        assert detail_response.status_code == 200
        data = detail_response.json()
        assert len(data.get("history", [])) >= 3  # create, process, complete


