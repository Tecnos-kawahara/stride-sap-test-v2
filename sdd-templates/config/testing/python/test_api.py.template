class TestCreateXXX_RESOURCE:
    """Test XXX_RESOURCE creation.

    Plan Reference: TS-UNIT-01, TS-UNIT-02
    """

    def test_create_success(self, client, buyer_session, sample_data):
        """
        @ac AC-US-FEATXXX-001-01 - XXX can be created with valid data

        Given: Authenticated buyer user
        When: POST /api/v1/xxx_resource with valid data
        Then: Returns 201 with created resource
        """
        response = client.post(
            "/api/v1/xxx_resource",
            json=sample_data,
            headers={"Idempotency-Key": str(uuid.uuid4())},
        )

        assert response.status_code == 201
        data = response.json()
        assert "id" in data
        assert data["status"] == "created"

    def test_create_requires_auth(self, client):
        """
        @ac AC-US-FEATXXX-001-02 - Unauthenticated users cannot create

        Given: No authentication
        When: POST /api/v1/xxx_resource
        Then: Returns 401 Unauthorized
        """
        response = client.post(
            "/api/v1/xxx_resource",
            json={"name": "test"},
        )

        assert response.status_code == 401

    def test_create_idempotency(self, client, buyer_session, sample_data):
        """
        @ac AC-US-FEATXXX-001-03 - Duplicate requests return same result

        Given: Authenticated user with idempotency key
        When: POST same request twice with same key
        Then: Returns same resource (no duplicate)
        """
        idempotency_key = str(uuid.uuid4())

        # First request
        response1 = client.post(
            "/api/v1/xxx_resource",
            json=sample_data,
            headers={"Idempotency-Key": idempotency_key},
        )
        assert response1.status_code == 201
        id1 = response1.json()["id"]

        # Second request with same key
        response2 = client.post(
            "/api/v1/xxx_resource",
            json=sample_data,
            headers={"Idempotency-Key": idempotency_key},
        )
        assert response2.status_code == 201
        id2 = response2.json()["id"]

        assert id1 == id2  # Same resource returned

    def test_create_validation_error(self, client, buyer_session):
        """
        @ac AC-US-FEATXXX-001-04 - Invalid data returns validation error

        Given: Authenticated user
        When: POST with invalid/missing required fields
        Then: Returns 422 with error details
        """
        response = client.post(
            "/api/v1/xxx_resource",
            json={"invalid": "data"},
            headers={"Idempotency-Key": str(uuid.uuid4())},
        )

        assert response.status_code == 422
        data = response.json()
        assert "detail" in data


