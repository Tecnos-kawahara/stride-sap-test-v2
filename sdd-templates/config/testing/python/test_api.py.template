class TestListXXX_RESOURCE:
    """Test XXX_RESOURCE listing.

    Plan Reference: TS-UNIT-03, TS-UNIT-04
    """

    def test_list_empty(self, client, buyer_session):
        """
        @ac AC-US-FEATXXX-002-01 - Empty list returns empty array

        Given: Authenticated user with no resources
        When: GET /api/v1/xxx_resource
        Then: Returns empty list with pagination info
        """
        response = client.get("/api/v1/xxx_resource")

        assert response.status_code == 200
        data = response.json()
        assert data["items"] == []
        assert data["total"] == 0

    def test_list_with_data(self, client, buyer_session, created_resource):
        """
        @ac AC-US-FEATXXX-002-02 - List returns all user's resources

        Given: Authenticated user with created resources
        When: GET /api/v1/xxx_resource
        Then: Returns list with resources
        """
        response = client.get("/api/v1/xxx_resource")

        assert response.status_code == 200
        data = response.json()
        assert len(data["items"]) >= 1
        assert "id" in data["items"][0]

    def test_list_pagination(self, client, buyer_session, multiple_resources):
        """
        @ac AC-US-FEATXXX-002-03 - Pagination works correctly

        Given: Multiple resources exist
        When: GET with page and size params
        Then: Returns paginated results
        """
        response = client.get("/api/v1/xxx_resource?page=1&size=2")

        assert response.status_code == 200
        data = response.json()
        assert len(data["items"]) <= 2
        assert data["page"] == 1
        assert data["size"] == 2

    def test_list_with_filter(self, client, buyer_session, created_resource):
        """
        @ac AC-US-FEATXXX-002-04 - Filtering by status works

        Given: Resources with various statuses
        When: GET with status filter
        Then: Returns only matching resources
        """
        response = client.get("/api/v1/xxx_resource?status=active")

        assert response.status_code == 200
        data = response.json()
        for item in data["items"]:
            assert item["status"] == "active"

    def test_list_with_date_range(self, client, buyer_session, created_resource):
        """
        @ac AC-US-FEATXXX-002-05 - Date range filtering works

        Given: Resources created on various dates
        When: GET with date_from and date_to
        Then: Returns resources within range
        """
        today = date.today()
        response = client.get(
            f"/api/v1/xxx_resource?date_from={today}&date_to={today + timedelta(days=1)}"
        )

        assert response.status_code == 200


