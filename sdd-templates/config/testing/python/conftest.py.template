@pytest.fixture(scope="function")
def buyer_user(client, db_session) -> dict:
    """
    Create a buyer user for testing.

    Returns:
        dict: User data with id, username, company info
    """
    # Create company first
    from src.domain.models import Company, User
    from src.auth.password import hash_password

    company = Company(
        id=uuid.uuid4(),
        name="Test Buyer Company",
        company_type="buyer",
    )
    db_session.add(company)

    user = User(
        id=uuid.uuid4(),
        username="buyer_user",
