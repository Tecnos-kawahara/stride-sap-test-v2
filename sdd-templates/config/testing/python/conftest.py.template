@pytest.fixture(scope="function")
def supplier_company(supplier_user, db_session):
    """
    Get the supplier's company for order creation.

    Usage:
        def test_create_order(client, buyer_session, supplier_company):
            response = client.post("/api/v1/orders", json={
                "supplier_id": str(supplier_company.id),
                ...
            })
    """
    from src.domain.models import Company

    company = db_session.query(Company).filter(
        Company.id == uuid.UUID(supplier_user["company_id"])
    ).first()
    return company


