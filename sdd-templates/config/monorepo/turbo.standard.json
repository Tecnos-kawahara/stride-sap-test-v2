{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json"
  ],
  "tasks": {
    "lint": {
      "dependsOn": [],
      "outputs": [],
      "cache": true,
      "inputs": ["src/**/*.{ts,js,tsx,jsx}"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": true,
      "inputs": ["src/**/*.{ts,tsx}", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": true,
      "inputs": ["src/**", "tests/**", "test/**", "vitest.config.*", "tsconfig.json"],
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:coverage": {
      "dependsOn": ["^typecheck"],
      "outputs": ["coverage/**"],
      "cache": true,
      "inputs": ["src/**", "tests/**", "test/**", "vitest.config.*", "tsconfig.json"],
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:contract": {
      "dependsOn": ["^typecheck"],
      "outputs": ["test-results/**"],
      "cache": true,
      "inputs": ["tests/**", "contracts/**"]
    },
    "spec:drift": {
      "dependsOn": [],
      "outputs": [],
      "cache": true,
      "inputs": ["contracts/**", "src/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true,
      "inputs": ["src/**", "tsconfig.json"]
    }
  }
}
